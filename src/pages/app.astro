    }

    // Projects
    if (d.projects) {
      html += `<section class="mb-4"><h2 class="rr-section-title">Projects</h2>`;
      d.projects.split('\n').filter((l: string) => l.trim()).forEach((line: string) => {
        html += `<div class="mb-2"><p class="text-xs text-gray-700 leading-relaxed">${line.trim()}</p></div>`;
      });
      html += `</section>`;
    }

    // Education
    if (d.education && d.education.length > 0) {
      html += `<section class="mb-4"><h2 class="rr-section-title">Education</h2><div class="space-y-3">`;
      d.education.forEach((edu: any) => {
        html += `<div class="flex items-start justify-between gap-2">
          <div>
            <div class="text-sm font-bold text-gray-900">${edu.degree}${edu.branch ? ', ' + edu.branch : ''}</div>
            <div class="text-xs text-gray-600">${edu.college}</div>
            ${edu.cgpa ? `<div class="text-xs text-gray-500 mt-0.5">${edu.cgpa}</div>` : ''}
          </div>
          ${edu.year ? `<div class="text-xs text-gray-500 whitespace-nowrap mt-0.5">${edu.year}</div>` : ''}
        </div>`;
      });
      html += `</div></section>`;
