            <svg class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-900 mb-2">Unlock Your Resume</h2>
          <p class="text-gray-500 text-sm mb-6">Your ATS-optimized resume is ready. Download the full PDF for just ₹9.</p>
          <div class="bg-gray-50 rounded-xl p-4 mb-6">
            <div class="flex items-center justify-between text-sm"><span class="text-gray-600">ATS-Optimized Resume PDF</span><span class="font-bold text-gray-900">₹9</span></div>
            <div class="flex items-center justify-between text-xs text-gray-400 mt-1"><span>One-time payment</span><span class="line-through">₹299</span></div>
          </div>
          <div class="flex items-center justify-center gap-2 mb-5 flex-wrap">
            <div class="flex items-center gap-1.5 bg-gray-50 border border-gray-100 rounded-lg px-3 py-2 text-xs font-medium text-gray-600"><span>🇮🇳</span> UPI</div>
            <div class="flex items-center gap-1.5 bg-gray-50 border border-gray-100 rounded-lg px-3 py-2 text-xs font-medium text-gray-600"><span>📱</span> GPay</div>
            <div class="flex items-center gap-1.5 bg-gray-50 border border-gray-100 rounded-lg px-3 py-2 text-xs font-medium text-gray-600"><span>💜</span> PhonePe</div>
            <div class="flex items-center gap-1.5 bg-gray-50 border border-gray-100 rounded-lg px-3 py-2 text-xs font-medium text-gray-600"><span>💙</span> Paytm</div>
          </div>
          <!-- Pay button -->
          <button id="btn-pay" class="btn-primary w-full py-4 text-base flex items-center justify-center gap-2">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
            Pay ₹9 & Download PDF
          </button>
          <div id="pay-error" class="hidden mt-3 text-xs text-red-500 bg-red-50 rounded-lg p-2"></div>
          <p class="text-xs text-gray-400 mt-3">Secure payment · Instant download · No account needed</p>
        </div>
      </div>
    </div>

    <!-- Razorpay SDK -->
    <script src="https://checkout.razorpay.com/v1/checkout.js" is:inline></script>

  </main>
</Layout>
<script>
  // ── Populate datalists from FormData ──
  function populateDatalist(id: string, items: string[]) {
    const dl = document.getElementById(id) as HTMLDataListElement;
    if (!dl) return;
    dl.innerHTML = items.map(i => `<option value="${i}">`).join('');
  }

  const w = window as any;
  if (w.INDIA_CITIES) populateDatalist('cities-list', w.INDIA_CITIES);
  if (w.ALL_CERTS) populateDatalist('certs-list', w.ALL_CERTS);
  if (w.ALL_ROLES) {
    const allRoles: string[] = [];
    Object.values(w.ALL_ROLES as Record<string, string[]>).forEach(arr => allRoles.push(...arr));
    populateDatalist('roles-list', allRoles);
  }

  // ── Populate industry dropdown ──
  const industrySelects = document.querySelectorAll('#fix-industry');
  if (w.ALL_INDUSTRIES) {
    industrySelects.forEach(sel => {
      (w.ALL_INDUSTRIES as string[]).forEach((ind: string) => {
        const opt = document.createElement('option');
        opt.value = ind; opt.textContent = ind;
        sel.appendChild(opt);
      });
    });
  }

  // ── Skill category tabs ──
  const catTabs = document.getElementById('skill-cat-tabs');
  const chipsContainer = document.getElementById('skill-chips-container');
  const selectedSkills = new Set<string>();

  if (catTabs && chipsContainer && w.SKILLS_BY_CATEGORY) {
    const cats = Object.keys(w.SKILLS_BY_CATEGORY as Record<string, string[]>);
    let activecat = cats[0];

    function renderCatTabs() {
      catTabs!.innerHTML = cats.map(cat => `
        <button type="button" class="cat-tab text-xs px-3 py-1.5 rounded-full border transition-all duration-150 font-medium ${cat === activecat ? 'bg-brand-600 text-white border-brand-600' : 'bg-white text-gray-500 border-gray-200 hover:border-brand-400 hover:text-brand-600'}" data-cat="${cat}">${cat}</button>
      `).join('');
      catTabs!.querySelectorAll('.cat-tab').forEach(btn => {
        btn.addEventListener('click', () => {
          activecat = (btn as HTMLElement).dataset.cat!;
          renderCatTabs();
          renderSkillChips();
        });
      });
    }

    function renderSkillChips() {
      const skills: string[] = (w.SKILLS_BY_CATEGORY as Record<string, string[]>)[activecat] || [];
      chipsContainer!.innerHTML = skills.map(s => `
        <button type="button" class="skill-chip ${selectedSkills.has(s) ? 'active' : ''}" data-skill="${s}">${s}</button>
      `).join('');
      chipsContainer!.querySelectorAll('.skill-chip').forEach(btn => {
        btn.addEventListener('click', () => {
          const skill = (btn as HTMLElement).dataset.skill!;
          if (selectedSkills.has(skill)) selectedSkills.delete(skill);
          else selectedSkills.add(skill);
          renderSkillChips();
          updateSelectedSkillsDisplay();
        });
      });
    }

    function updateSelectedSkillsDisplay() {
      const display = document.getElementById('selected-skills-display')!;
      const list = document.getElementById('selected-skills-list')!;
      if (selectedSkills.size > 0) {
        display.classList.remove('hidden');
        list.innerHTML = Array.from(selectedSkills).map(s =>
          `<span class="text-xs bg-brand-100 text-brand-700 px-2 py-0.5 rounded-full font-medium flex items-center gap-1">${s}<button type="button" onclick="window.__removeSkill('${s}')" class="ml-0.5 text-brand-400 hover:text-brand-700">×</button></span>`
        ).join('');
      } else {
        display.classList.add('hidden');
      }
    }

    (window as any).__removeSkill = (skill: string) => {
      selectedSkills.delete(skill);
      renderSkillChips();
      updateSelectedSkillsDisplay();
    };

    renderCatTabs();
    renderSkillChips();
  }

  // ── Mode tabs ──
  const tabFix = document.getElementById('tab-fix')!;
  const tabNew = document.getElementById('tab-new')!;
  const formFix = document.getElementById('form-fix')!;
  const formNew = document.getElementById('form-new')!;
  const activeTabCls = 'flex-1 flex items-center justify-center gap-2 py-3 px-4 rounded-xl text-sm font-semibold transition-all duration-200 bg-brand-600 text-white shadow-sm';
  const inactiveTabCls = 'flex-1 flex items-center justify-center gap-2 py-3 px-4 rounded-xl text-sm font-semibold transition-all duration-200 text-gray-500 hover:text-gray-700';

  tabFix.addEventListener('click', () => {
    tabFix.className = activeTabCls; tabNew.className = inactiveTabCls;
    formFix.classList.remove('hidden'); formNew.classList.add('hidden');
  });
  tabNew.addEventListener('click', () => {
    tabNew.className = activeTabCls; tabFix.className = inactiveTabCls;
    formNew.classList.remove('hidden'); formFix.classList.add('hidden');
  });

  // ── Paste/Upload toggle ──
  document.getElementById('fix-tab-paste')?.addEventListener('click', function() {
    document.getElementById('fix-paste-area')!.classList.remove('hidden');
    document.getElementById('fix-upload-area')!.classList.add('hidden');
    this.className = 'flex-1 py-2 text-xs font-semibold rounded-lg bg-white shadow-sm text-gray-800 transition-all';
    document.getElementById('fix-tab-upload')!.className = 'flex-1 py-2 text-xs font-semibold rounded-lg text-gray-500 transition-all';
  });
  document.getElementById('fix-tab-upload')?.addEventListener('click', function() {
    document.getElementById('fix-upload-area')!.classList.remove('hidden');
    document.getElementById('fix-paste-area')!.classList.add('hidden');
    this.className = 'flex-1 py-2 text-xs font-semibold rounded-lg bg-white shadow-sm text-gray-800 transition-all';
    document.getElementById('fix-tab-paste')!.className = 'flex-1 py-2 text-xs font-semibold rounded-lg text-gray-500 transition-all';
  });

  // ── Multi-step navigation ──
  function goToStep(n: number) {
    [1,2,3,4].forEach(i => {
      document.getElementById(`new-step-${i}`)?.classList.toggle('hidden', i !== n);
      const dot = document.querySelector(`[data-step="${i}"]`) as HTMLElement;
      const line = document.querySelector(`[data-line="${i}"]`) as HTMLElement;
      if (dot) dot.className = `step-dot w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold transition-all duration-300 ${i <= n ? 'bg-brand-600 text-white' : 'bg-gray-100 text-gray-400'}`;
      if (line) line.className = `step-line flex-1 h-0.5 transition-all duration-300 ${i < n ? 'bg-brand-400' : 'bg-gray-100'}`;
    });
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
  document.querySelectorAll('.next-step').forEach(btn => btn.addEventListener('click', () => goToStep(parseInt((btn as HTMLElement).dataset.next || '1'))));
  document.querySelectorAll('.prev-step').forEach(btn => btn.addEventListener('click', () => goToStep(parseInt((btn as HTMLElement).dataset.prev || '1'))));

  // ── Chip toggles ──
  document.querySelectorAll('.focus-chip, .resp-chip').forEach(chip => {
    chip.addEventListener('click', () => chip.classList.toggle('active'));
  });
  document.querySelectorAll('.skill-chip').forEach(chip => {
    chip.addEventListener('click', () => chip.classList.toggle('active'));
  });
  document.querySelectorAll('.lang-chip').forEach(chip => {
    chip.addEventListener('click', () => chip.classList.toggle('active'));
  });

  // ── Currently working checkbox ──
  document.addEventListener('change', (e) => {
    const cb = e.target as HTMLInputElement;
    if (cb.classList.contains('currently-working')) {
      const endDate = cb.closest('.space-y-3')?.querySelector('.exp-end-date') as HTMLInputElement;
      if (endDate) { endDate.disabled = cb.checked; if (cb.checked) endDate.value = ''; }
    }
  });

  // ── Experience type toggle (experienced vs fresher) ──
  const expTypeBtns = {
    experienced: document.getElementById('exp-type-experienced')!,
    fresher: document.getElementById('exp-type-fresher')!,
  };
  const expSections = {
    experienced: document.getElementById('exp-experienced-section')!,
    fresher: document.getElementById('exp-fresher-section')!,
  };
  const activeCls = 'flex-1 py-2.5 text-xs font-semibold rounded-lg bg-white shadow-sm text-gray-800 transition-all flex items-center justify-center gap-1.5';
  const inactiveCls = 'flex-1 py-2.5 text-xs font-semibold rounded-lg text-gray-500 transition-all flex items-center justify-center gap-1.5';

  expTypeBtns.experienced?.addEventListener('click', () => {
    expTypeBtns.experienced.className = activeCls;
    expTypeBtns.fresher.className = inactiveCls;
    expSections.experienced.classList.remove('hidden');
    expSections.fresher.classList.add('hidden');
  });
  expTypeBtns.fresher?.addEventListener('click', () => {
    expTypeBtns.fresher.className = activeCls;
    expTypeBtns.experienced.className = inactiveCls;
    expSections.fresher.classList.remove('hidden');
    expSections.experienced.classList.add('hidden');
  });

  // ── Add fresher project entry ──
  document.getElementById('add-fresher-project')?.addEventListener('click', () => {
    const container = document.getElementById('fresher-projects')!;
    const entry = container.querySelector('.fresher-project')!.cloneNode(true) as HTMLElement;
    entry.querySelectorAll('input, textarea, select').forEach((el: any) => el.value = '');
    const removeBtn = document.createElement('button');
    removeBtn.type = 'button';
    removeBtn.className = 'text-xs text-red-400 hover:text-red-600 mt-1 transition-colors';
    removeBtn.textContent = '✕ Remove this project';
    removeBtn.addEventListener('click', () => entry.remove());
    entry.appendChild(removeBtn);
    container.appendChild(entry);
  });

  // ── Add more experience entries ──
  document.getElementById('add-exp')?.addEventListener('click', () => {
    const container = document.getElementById('exp-entries')!;
    const entry = container.querySelector('.exp-entry')!.cloneNode(true) as HTMLElement;
    entry.querySelectorAll('input, textarea, select').forEach((el: any) => el.value = '');
    entry.querySelectorAll('.resp-chip').forEach(c => c.classList.remove('active'));
    const removeBtn = document.createElement('button');
    removeBtn.type = 'button';
    removeBtn.className = 'text-xs text-red-400 hover:text-red-600 mt-1 transition-colors';
    removeBtn.textContent = '✕ Remove this entry';
    removeBtn.addEventListener('click', () => entry.remove());
    entry.appendChild(removeBtn);
    container.appendChild(entry);
  });

  // ── Add more education entries ──
  document.getElementById('add-edu')?.addEventListener('click', () => {
    const container = document.getElementById('edu-entries')!;
    const entry = container.querySelector('.edu-entry')!.cloneNode(true) as HTMLElement;
    entry.querySelectorAll('input, select').forEach((el: any) => el.value = '');
    const removeBtn = document.createElement('button');
    removeBtn.type = 'button';
    removeBtn.className = 'text-xs text-red-400 hover:text-red-600 mt-1 transition-colors';
    removeBtn.textContent = '✕ Remove this entry';
    removeBtn.addEventListener('click', () => entry.remove());
    entry.appendChild(removeBtn);
    container.appendChild(entry);
  });

  // ── File upload ──
  const fileUpload = document.getElementById('file-upload') as HTMLInputElement;
  const fileName = document.getElementById('file-name')!;
  fileUpload?.addEventListener('change', () => {
    const file = fileUpload.files?.[0];
    if (file) { fileName.classList.remove('hidden'); fileName.textContent = `✓ ${file.name}`; }
  });

  // ── Collect all form data ──
  function collectFormData() {
    const isNew = !formFix.classList.contains('hidden') === false;
    const mode = formNew.classList.contains('hidden') ? 'fix' : 'new';

    if (mode === 'fix') {
      return {
        mode: 'fix',
        resumeText: (document.getElementById('resume-input') as HTMLTextAreaElement)?.value || '',
        role: (document.getElementById('fix-role') as HTMLInputElement)?.value || '',
        level: (document.getElementById('fix-level') as HTMLSelectElement)?.value || '',
        industry: (document.getElementById('fix-industry') as HTMLSelectElement)?.value || '',
        jd: (document.getElementById('jd-input') as HTMLTextAreaElement)?.value || '',
      };
    }

    // Detect if fresher mode is active
    const isFresher = !document.getElementById('exp-fresher-section')?.classList.contains('hidden');

    if (isFresher) {
      // Collect fresher data
      const fresherProjects: any[] = [];
      document.querySelectorAll('.fresher-project').forEach(entry => {
        const inputs = entry.querySelectorAll('input');
        const selects = entry.querySelectorAll('select');
        const textarea = entry.querySelector('textarea') as HTMLTextAreaElement;
        const name = (inputs[0] as HTMLInputElement)?.value || '';
        const type = (selects[0] as HTMLSelectElement)?.value || '';
        const tech = (inputs[1] as HTMLInputElement)?.value || '';
        const desc = textarea?.value || '';
        const result = (inputs[2] as HTMLInputElement)?.value || '';
        if (name || desc) fresherProjects.push({ name, type, tech, desc, result });
      });

      const activities = Array.from(document.querySelectorAll('#exp-fresher-section .resp-chip.active')).map(c => c.textContent?.trim() || '');

      return {
        mode: 'new',
        isFresher: true,
        name: (document.getElementById('n-name') as HTMLInputElement)?.value || '',
        title: (document.getElementById('n-title') as HTMLInputElement)?.value || '',
        email: (document.getElementById('n-email') as HTMLInputElement)?.value || '',
        phone: (document.getElementById('n-phone') as HTMLInputElement)?.value || '',
        location: (document.getElementById('n-location') as HTMLInputElement)?.value || '',
        level: (document.getElementById('n-exp-level') as HTMLSelectElement)?.value || '',
        linkedin: (document.getElementById('n-linkedin') as HTMLInputElement)?.value || '',
        github: (document.getElementById('n-github') as HTMLInputElement)?.value || '',
        summary: (document.getElementById('n-summary') as HTMLTextAreaElement)?.value || '',
        internship: {
          role: (document.getElementById('fresher-intern-role') as HTMLInputElement)?.value || '',
          company: (document.getElementById('fresher-intern-company') as HTMLInputElement)?.value || '',
          duration: (document.getElementById('fresher-intern-duration') as HTMLSelectElement)?.value || '',
          type: (document.getElementById('fresher-intern-type') as HTMLSelectElement)?.value || '',
          desc: (document.getElementById('fresher-intern-desc') as HTMLTextAreaElement)?.value || '',
        },
        fresherProjects,
        activities,
        extras: (document.getElementById('fresher-extras') as HTMLTextAreaElement)?.value || '',
        education: [],
        skills: [...new Set([...Array.from(document.querySelectorAll('.skill-chip.active')).map(c => c.textContent?.trim() || ''), ...((document.getElementById('n-skills-manual') as HTMLInputElement)?.value || '').split(',').map(s => s.trim()).filter(Boolean)])],
        languages: Array.from(document.querySelectorAll('.lang-chip.active')).map(c => c.textContent?.trim() || ''),
        certifications: (document.getElementById('n-certs') as HTMLInputElement)?.value || '',
        projects: (document.getElementById('n-projects') as HTMLTextAreaElement)?.value || '',
        jd: (document.getElementById('n-jd') as HTMLTextAreaElement)?.value || '',
      };
    }
    const expEntries: any[] = [];
    document.querySelectorAll('.exp-entry').forEach(entry => {
      const inputs = entry.querySelectorAll('input, select, textarea');
      const title = (inputs[0] as HTMLInputElement)?.value || '';
      const type = (inputs[1] as HTMLSelectElement)?.value || '';
      const company = (inputs[2] as HTMLInputElement)?.value || '';
      const location = (inputs[3] as HTMLInputElement)?.value || '';
      const startDate = (inputs[4] as HTMLInputElement)?.value || '';
      const endDate = (inputs[5] as HTMLInputElement)?.value || '';
      const isCurrent = (entry.querySelector('.currently-working') as HTMLInputElement)?.checked || false;
      const achievements = (entry.querySelector('textarea') as HTMLTextAreaElement)?.value || '';
      const responsibilities = Array.from(entry.querySelectorAll('.resp-chip.active')).map(c => c.textContent?.trim() || '');
      if (title || company) expEntries.push({ title, type, company, location, startDate, endDate, isCurrent, achievements, responsibilities });
    });

    // Collect education entries
    const eduEntries: any[] = [];
    document.querySelectorAll('.edu-entry').forEach(entry => {
      const selects = entry.querySelectorAll('select');
      const inputs = entry.querySelectorAll('input');
      const degree = (selects[0] as HTMLSelectElement)?.value || '';
      const branch = (selects[1] as HTMLSelectElement)?.value || '';
      const college = (inputs[0] as HTMLInputElement)?.value || '';
      const year = (selects[2] as HTMLSelectElement)?.value || '';
      const cgpa = (selects[3] as HTMLSelectElement)?.value || '';
      if (degree || college) eduEntries.push({ degree, branch, college, year, cgpa });
    });

    // Collect selected skills
    const chipSkills = Array.from(document.querySelectorAll('.skill-chip.active')).map(c => c.textContent?.trim() || '');
    const manualSkills = ((document.getElementById('n-skills-manual') as HTMLInputElement)?.value || '').split(',').map(s => s.trim()).filter(Boolean);
    const allSkills = [...new Set([...chipSkills, ...manualSkills])];

    // Languages
    const langs = Array.from(document.querySelectorAll('#new-step-4 .skill-chip.active')).map(c => c.textContent?.trim() || '');

    return {
      mode: 'new',
      name: (document.getElementById('n-name') as HTMLInputElement)?.value || '',
      title: (document.getElementById('n-title') as HTMLInputElement)?.value || '',
      email: (document.getElementById('n-email') as HTMLInputElement)?.value || '',
      phone: (document.getElementById('n-phone') as HTMLInputElement)?.value || '',
      location: (document.getElementById('n-location') as HTMLInputElement)?.value || '',
      level: (document.getElementById('n-exp-level') as HTMLSelectElement)?.value || '',
      linkedin: (document.getElementById('n-linkedin') as HTMLInputElement)?.value || '',
      github: (document.getElementById('n-github') as HTMLInputElement)?.value || '',
      summary: (document.getElementById('n-summary') as HTMLTextAreaElement)?.value || '',
      experience: expEntries,
      education: eduEntries,
      skills: allSkills,
      languages: langs,
      certifications: (document.getElementById('n-certs') as HTMLInputElement)?.value || '',
      projects: (document.getElementById('n-projects') as HTMLTextAreaElement)?.value || '',
      jd: (document.getElementById('n-jd') as HTMLTextAreaElement)?.value || '',
    };
  }

  // ── Format month string ──
  function fmtMonth(val: string) {
    if (!val) return '';
    const [y, m] = val.split('-');
    const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    return `${months[parseInt(m)-1]} ${y}`;
  }

  // ── Build resume HTML from data ──
  function buildResumeHTML(data: any): string {
    if (data.mode === 'fix') {
      // For fix mode: show parsed resume text in clean format
      return buildFixModeResume(data);
    }
    return buildNewModeResume(data);
  }

  function buildFixModeResume(data: any): string {
    const lines = data.resumeText.trim().split('\n').filter((l: string) => l.trim());
    const name = lines[0] || 'Your Name';
    const contact = lines.slice(1, 4).join(' · ');
    const bodyLines = lines.slice(4);

    let sections: string[] = [];
    let currentSection = '';
    let currentContent: string[] = [];

    bodyLines.forEach((line: string) => {
      const isHeader = line.trim().length < 40 && line.trim() === line.trim().toUpperCase() && line.trim().length > 2;
      if (isHeader) {
        if (currentSection) sections.push(`<section class="mb-4"><h2 class="rr-section-title">${currentSection}</h2><div class="space-y-1 text-xs text-gray-700 leading-relaxed">${currentContent.map(l => `<p>${l}</p>`).join('')}</div></section>`);
        currentSection = line.trim();
        currentContent = [];
      } else {
        currentContent.push(line.trim());
      }
    });
    if (currentSection) sections.push(`<section class="mb-4"><h2 class="rr-section-title">${currentSection}</h2><div class="space-y-1 text-xs text-gray-700 leading-relaxed">${currentContent.map(l => `<p>${l}</p>`).join('')}</div></section>`);

    return `
      <header class="border-b-2 border-gray-900 pb-3 mb-4">
        <h1 class="text-2xl font-bold text-gray-900">${name}</h1>
        ${data.role ? `<p class="text-sm text-gray-600 mt-0.5 font-medium">${data.role}</p>` : ''}
        <p class="text-xs text-gray-500 mt-1">${contact}</p>
      </header>
      ${sections.join('')}
      <div class="mt-4 pt-3 border-t border-gray-100 text-xs text-gray-400 text-center">AI-optimized for ATS · ResumeRocket AI</div>
    `;
  }

  function buildFresherResume(d: any): string {
    const name = d.name || 'Your Name';
    const title = d.title || 'Fresher';
    const email = d.email || '';
    const phone = d.phone || '';
    const location = d.location || '';
    const linkedin = d.linkedin || '';
    const github = d.github || '';

    let html = `<header class="border-b-2 border-gray-900 pb-3 mb-4">
      <h1 class="text-2xl font-bold tracking-tight text-gray-900 leading-none">${name}</h1>
      <p class="text-sm text-gray-600 mt-1 font-medium">${title}</p>
      <div class="flex flex-wrap gap-x-4 gap-y-0.5 mt-2 text-xs text-gray-500">
        ${email ? `<span>✉ ${email}</span>` : ''}
        ${phone ? `<span>📞 ${phone}</span>` : ''}
        ${location ? `<span>📍 ${location}</span>` : ''}
        ${linkedin ? `<span class="text-blue-700">🔗 ${linkedin.replace(/^https?:\/\//, '')}</span>` : ''}
        ${github ? `<span class="text-blue-700">⌥ ${github.replace(/^https?:\/\//, '')}</span>` : ''}
      </div>
    </header>`;

    // Summary — auto-generate for freshers
    const skillsPreview = d.skills?.slice(0, 4).join(', ') || 'relevant technologies';
    html += `<section class="mb-4">
      <h2 class="rr-section-title">Objective</h2>
      <p class="text-xs text-gray-700 leading-relaxed">
        ${d.summary || `Motivated ${title} graduate with strong foundation in ${skillsPreview}. Eager to apply academic knowledge and project experience in a professional environment. Quick learner with a passion for continuous growth and delivering quality work.`}
      </p>
    </section>`;

    // Internship
    const intern = d.internship;
    if (intern?.role || intern?.company) {
      html += `<section class="mb-4">
        <h2 class="rr-section-title">Internship / Training</h2>
        <div class="flex items-start justify-between gap-2">
          <div>
            <div class="text-sm font-bold text-gray-900">${intern.role || 'Intern'}</div>
            <div class="text-xs font-semibold text-gray-600">${intern.company}${intern.type ? ' · ' + intern.type : ''}</div>
          </div>
          ${intern.duration ? `<div class="text-xs text-gray-500 whitespace-nowrap">${intern.duration}</div>` : ''}
        </div>
        ${intern.desc ? `<ul class="mt-1.5 text-xs text-gray-700 leading-relaxed space-y-1">
          ${intern.desc.split('\n').filter((l: string) => l.trim()).map((l: string) =>
            `<li class="flex gap-2"><span class="flex-shrink-0">•</span><span>${l.trim().replace(/^[-•]\s*/,'')}</span></li>`
          ).join('')}
        </ul>` : ''}
      </section>`;
    }

    // Projects
    if (d.fresherProjects?.length > 0) {
      html += `<section class="mb-4"><h2 class="rr-section-title">Projects</h2><div class="space-y-3">`;
      d.fresherProjects.forEach((p: any) => {
        if (!p.name && !p.desc) return;
        html += `<div>
          <div class="flex items-start justify-between gap-2">
            <span class="text-xs font-bold text-gray-900">${p.name || 'Project'}${p.type ? ` <span class="font-normal text-gray-400">· ${p.type}</span>` : ''}</span>
          </div>
          ${p.tech ? `<p class="text-xs text-gray-400 mt-0.5">${p.tech}</p>` : ''}
          ${p.desc ? `<p class="text-xs text-gray-700 mt-0.5 leading-relaxed">${p.desc}</p>` : ''}
          ${p.result ? `<p class="text-xs text-accent-600 mt-0.5 font-medium">✓ ${p.result}</p>` : ''}
        </div>`;
      });
      html += `</div></section>`;
    }

    // Education (will be filled from step 3 data — placeholder here)
    if (d.education?.length > 0) {
      html += `<section class="mb-4"><h2 class="rr-section-title">Education</h2><div class="space-y-3">`;
      d.education.forEach((edu: any) => {
        html += `<div class="flex items-start justify-between gap-2">
          <div>
            <div class="text-sm font-bold text-gray-900">${edu.degree}${edu.branch ? ', ' + edu.branch : ''}</div>
            <div class="text-xs text-gray-600">${edu.college}</div>
            ${edu.cgpa ? `<div class="text-xs text-gray-500 mt-0.5">${edu.cgpa}</div>` : ''}
          </div>
          ${edu.year ? `<div class="text-xs text-gray-500 whitespace-nowrap">${edu.year}</div>` : ''}
        </div>`;
      });
      html += `</div></section>`;
    }

    // Skills
    if (d.skills?.length > 0) {
      html += `<section class="mb-4"><h2 class="rr-section-title">Technical Skills</h2>
        <p class="text-xs text-gray-700 leading-relaxed">${d.skills.join(' · ')}</p>
      </section>`;
    }

    // Activities & Achievements
    const allActivities = [...(d.activities || [])];
    if (d.extras) allActivities.push(d.extras);
    if (allActivities.length > 0) {
      html += `<section class="mb-4"><h2 class="rr-section-title">Achievements & Activities</h2>
        <ul class="space-y-1 text-xs text-gray-700">
          ${allActivities.map(a => `<li class="flex gap-2"><span class="flex-shrink-0">•</span><span>${a}</span></li>`).join('')}
        </ul>
      </section>`;
    }

    // Certifications
    if (d.certifications) {
      html += `<section class="mb-4"><h2 class="rr-section-title">Certifications</h2>
        <p class="text-xs text-gray-700">${d.certifications}</p>
      </section>`;
    }

    // Languages
    if (d.languages?.length > 0) {
      html += `<section class="mb-2"><h2 class="rr-section-title">Languages</h2>
        <p class="text-xs text-gray-700">${d.languages.join(' · ')}</p>
      </section>`;
    }

    html += `<div class="mt-4 pt-3 border-t border-gray-100 text-xs text-gray-400 text-center">AI-optimized for ATS · ResumeRocket AI</div>`;
    return html;
  }

  function buildNewModeResume(d: any): string {
