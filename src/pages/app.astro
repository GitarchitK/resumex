        ${location ? `<span>📍 ${location}</span>` : ''}
        ${linkedin ? `<span class="text-blue-700">🔗 ${linkedin.replace(/^https?:\/\//, '')}</span>` : ''}
        ${github ? `<span class="text-blue-700">⌥ ${github.replace(/^https?:\/\//, '')}</span>` : ''}
      </div>
    </header>`;

    // Summary
    if (d.summary) {
      html += `<section class="mb-4">
