---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import FormData from '../components/FormData.astro';
---
<Layout title="ResumeRocket AI – Build or Fix Your Resume">
  <Navbar />
  <FormData />
  <main class="min-h-screen bg-gray-50 pt-20">

    <!-- datalists for city autocomplete -->
    <datalist id="cities-list"></datalist>
    <datalist id="roles-list"></datalist>
    <datalist id="certs-list"></datalist>

    <!-- ══════════════════════════════════════
         INPUT SCREEN
    ══════════════════════════════════════ -->
    <div id="screen-input" class="max-w-3xl mx-auto px-4 sm:px-6 py-10">

      <div class="text-center mb-8">
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-2">Your Resume, Perfected</h1>
        <p class="text-gray-500 text-sm sm:text-base">Fix your old resume or build a brand new one — AI does the heavy lifting.</p>
      </div>

      <!-- Mode Toggle -->
      <div class="flex bg-white border border-gray-200 rounded-2xl p-1.5 mb-6 shadow-sm">
        <button id="tab-fix" class="flex-1 flex items-center justify-center gap-2 py-3 px-4 rounded-xl text-sm font-semibold transition-all duration-200 bg-brand-600 text-white shadow-sm">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          Fix Existing Resume
        </button>
        <button id="tab-new" class="flex-1 flex items-center justify-center gap-2 py-3 px-4 rounded-xl text-sm font-semibold transition-all duration-200 text-gray-500 hover:text-gray-700">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
          Build New Resume
        </button>
      </div>

      <!-- ── FIX EXISTING FORM ── -->
      <div id="form-fix" class="card shadow-md space-y-5">
        <div class="flex items-start gap-3 bg-brand-50 border border-brand-100 rounded-xl p-4">
          <svg class="w-5 h-5 text-brand-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          <p class="text-sm text-brand-700">AI will analyze your resume, fix weak bullet points, add ATS keywords, and boost your score.</p>
        </div>

        <!-- Paste / Upload toggle -->
        <div>
          <div class="flex bg-gray-100 rounded-xl p-1 mb-3 gap-1">
            <button type="button" id="fix-tab-paste" class="flex-1 py-2 text-xs font-semibold rounded-lg bg-white shadow-sm text-gray-800 transition-all">📋 Paste Text</button>
            <button type="button" id="fix-tab-upload" class="flex-1 py-2 text-xs font-semibold rounded-lg text-gray-500 transition-all">📁 Upload File</button>
          </div>
          <div id="fix-paste-area">
            <textarea id="resume-input" rows="9" placeholder="Paste your full resume text here — work experience, education, skills, projects..."
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-700 placeholder-gray-300 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent resize-none transition-all"></textarea>
          </div>
          <div id="fix-upload-area" class="hidden">
            <label class="flex items-center justify-center gap-3 border-2 border-dashed border-gray-200 rounded-xl p-6 cursor-pointer hover:border-brand-400 hover:bg-brand-50/50 transition-all group">
              <svg class="w-6 h-6 text-gray-400 group-hover:text-brand-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg>
              <div class="text-center">
                <div class="text-sm font-semibold text-gray-600 group-hover:text-brand-600">Upload PDF or DOCX</div>
                <div class="text-xs text-gray-400 mt-0.5">Drag & drop or click to browse</div>
              </div>
              <input type="file" accept=".pdf,.docx" class="hidden" id="file-upload" />
            </label>
            <div id="file-name" class="text-xs text-accent-600 font-medium mt-1.5 ml-1 hidden"></div>
          </div>
        </div>

        <!-- Target Role — searchable combobox -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-semibold text-gray-700 mb-1.5">Target Role <span class="text-red-400">*</span></label>
            <input id="fix-role" list="roles-list" placeholder="Type or select your target role..." class="form-input" autocomplete="off" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-700 mb-1.5">Experience Level <span class="text-red-400">*</span></label>
            <select id="fix-level" class="form-select">
              <option value="">Select level</option>
              <option>Fresher / Intern (0–1 yr)</option>
              <option>Junior (1–3 yrs)</option>
              <option>Mid-level (3–6 yrs)</option>
              <option>Senior (6–10 yrs)</option>
              <option>Lead / Principal (10+ yrs)</option>
            </select>
          </div>
        </div>

        <!-- Industry + Job Type -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-semibold text-gray-700 mb-1.5">Industry</label>
            <select id="fix-industry" class="form-select">
              <option value="">Select industry</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-700 mb-1.5">Job Type</label>
            <select class="form-select">
              <option value="">Select type</option>
              <option>Full-time</option>
              <option>Internship</option>
              <option>Remote</option>
              <option>Hybrid</option>
              <option>Contract</option>
              <option>Freelance</option>
            </select>
          </div>
        </div>

        <!-- AI Focus chips -->
        <div>
          <label class="block text-xs font-semibold text-gray-700 mb-2">What should AI focus on? <span class="text-gray-400 font-normal">(pick all that apply)</span></label>
          <div class="flex flex-wrap gap-2">
            <button type="button" class="focus-chip">🔑 Add ATS Keywords</button>
            <button type="button" class="focus-chip">✍️ Rewrite Bullet Points</button>
            <button type="button" class="focus-chip">📊 Add Metrics</button>
            <button type="button" class="focus-chip">📝 Improve Summary</button>
            <button type="button" class="focus-chip">🛠️ Optimize Skills</button>
            <button type="button" class="focus-chip">📐 Fix Formatting</button>
            <button type="button" class="focus-chip">🕳️ Address Gaps</button>
          </div>
        </div>

        <!-- JD -->
        <div>
          <label class="block text-xs font-semibold text-gray-700 mb-1">Paste Job Description <span class="text-xs font-normal text-gray-400 ml-1">— optional but boosts match by 40%</span></label>
          <textarea id="jd-input" rows="3" placeholder="Paste the JD here to match keywords exactly for this role..."
            class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-700 placeholder-gray-300 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent resize-none transition-all"></textarea>
        </div>

        <button id="btn-fix" class="btn-primary w-full text-base py-4 flex items-center justify-center gap-2">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          Fix My Resume with AI
        </button>
        <p class="text-xs text-center text-gray-400">Free to analyze · ₹9 to download · No account needed</p>
      </div>

      <!-- ── BUILD NEW RESUME FORM ── -->
      <div id="form-new" class="hidden space-y-4">

        <!-- Step indicator -->
        <div class="flex items-center gap-2 mb-2">
          {[1,2,3,4].map((n) => (
            <div class="flex items-center gap-2 flex-1">
              <div class={`step-dot w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold transition-all duration-300 ${n===1?'bg-brand-600 text-white':'bg-gray-100 text-gray-400'}`} data-step={n}>{n}</div>
              {n < 4 && <div class={`step-line flex-1 h-0.5 transition-all duration-300 ${n===1?'bg-brand-200':'bg-gray-100'}`} data-line={n}></div>}
            </div>
          ))}
        </div>
        <div class="flex justify-between text-xs text-gray-400 mb-4">
          <span>Personal</span><span>Experience</span><span>Education</span><span>Skills</span>
        </div>

        <!-- STEP 1: Personal Info -->
        <div id="new-step-1" class="card shadow-md space-y-4">
          <div class="flex items-center gap-2 mb-1">
            <div class="w-7 h-7 bg-brand-100 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            </div>
            <h2 class="font-bold text-gray-900">Personal Information</h2>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-semibold text-gray-600 mb-1.5">Full Name <span class="text-red-400">*</span></label>
              <input type="text" id="n-name" placeholder="e.g. Priya Sharma" class="form-input" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 mb-1.5">Target Job Title <span class="text-red-400">*</span></label>
              <input id="n-title" list="roles-list" placeholder="Type or select your role..." class="form-input" autocomplete="off" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 mb-1.5">Email <span class="text-red-400">*</span></label>
              <input type="email" id="n-email" placeholder="priya@gmail.com" class="form-input" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 mb-1.5">Phone</label>
              <input type="tel" id="n-phone" placeholder="+91 98765 43210" class="form-input" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 mb-1.5">City <span class="text-red-400">*</span></label>
              <input id="n-location" list="cities-list" placeholder="Start typing your city..." class="form-input" autocomplete="off" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 mb-1.5">Experience Level <span class="text-red-400">*</span></label>
              <select id="n-exp-level" class="form-select">
                <option value="">Select level</option>
                <option>Fresher / Student (0–1 yr)</option>
                <option>Junior (1–3 yrs)</option>
                <option>Mid-level (3–6 yrs)</option>
                <option>Senior (6–10 yrs)</option>
                <option>Lead / Principal (10+ yrs)</option>
              </select>
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 mb-1.5">LinkedIn URL</label>
              <input type="url" id="n-linkedin" placeholder="linkedin.com/in/yourname" class="form-input" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 mb-1.5">GitHub / Portfolio URL</label>
              <input type="url" id="n-github" placeholder="github.com/yourname or yoursite.com" class="form-input" />
            </div>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-600 mb-1.5">Professional Summary <span class="text-gray-400 font-normal">(optional — AI will generate if blank)</span></label>
            <textarea id="n-summary" rows="3" placeholder="Brief intro about yourself. AI will improve it automatically."
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm placeholder-gray-300 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent resize-none transition-all"></textarea>
          </div>
          <button class="btn-primary w-full py-3 next-step" data-next="2">Continue to Experience →</button>
        </div>

        <!-- STEP 2: Work Experience -->
        <div id="new-step-2" class="hidden card shadow-md space-y-4">
          <div class="flex items-center gap-2 mb-2">
            <div class="w-7 h-7 bg-purple-100 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <h2 class="font-bold text-gray-900">Experience</h2>
          </div>

          <!-- Experience type toggle -->
          <div class="flex bg-gray-100 rounded-xl p-1 gap-1">
            <button type="button" id="exp-type-experienced"
              class="flex-1 py-2.5 text-xs font-semibold rounded-lg bg-white shadow-sm text-gray-800 transition-all flex items-center justify-center gap-1.5">
              💼 I have work experience
            </button>
            <button type="button" id="exp-type-fresher"
              class="flex-1 py-2.5 text-xs font-semibold rounded-lg text-gray-500 transition-all flex items-center justify-center gap-1.5">
              🎓 I'm a fresher / student
            </button>
          </div>

          <!-- ── EXPERIENCED: job entries ── -->
          <div id="exp-experienced-section">
            <div id="exp-entries" class="space-y-4">
              <div class="exp-entry bg-gray-50 rounded-xl p-4 space-y-3 border border-gray-100">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                  <div>
                    <label class="block text-xs font-semibold text-gray-600 mb-1.5">Job Title</label>
                    <input list="roles-list" placeholder="Type or select job title..." class="form-input bg-white" autocomplete="off" />
                  </div>
                  <div>
                    <label class="block text-xs font-semibold text-gray-600 mb-1.5">Employment Type</label>
                    <select class="form-select bg-white">
                      <option value="">Select type</option>
                      <option>Full-time</option>
                      <option>Internship</option>
                      <option>Part-time</option>
                      <option>Contract</option>
                      <option>Freelance</option>
                      <option>Apprenticeship</option>
                    </select>
                  </div>
                  <div>
                    <label class="block text-xs font-semibold text-gray-600 mb-1.5">Company Name</label>
                    <input type="text" placeholder="e.g. Infosys, Razorpay, Your Startup..." class="form-input bg-white" />
                  </div>
                  <div>
                    <label class="block text-xs font-semibold text-gray-600 mb-1.5">Company Location</label>
                    <input list="cities-list" placeholder="Start typing city..." class="form-input bg-white" autocomplete="off" />
                  </div>
                  <div>
                    <label class="block text-xs font-semibold text-gray-600 mb-1.5">Start Date</label>
                    <input type="month" class="form-input bg-white" />
                  </div>
                  <div>
                    <label class="block text-xs font-semibold text-gray-600 mb-1.5">End Date</label>
                    <input type="month" class="form-input bg-white exp-end-date" />
                    <label class="flex items-center gap-2 text-xs text-gray-500 cursor-pointer mt-1.5">
                      <input type="checkbox" class="rounded currently-working" /> Currently working here
                    </label>
                  </div>
                </div>
                <div>
                  <label class="block text-xs font-semibold text-gray-600 mb-1.5">Key Responsibilities <span class="text-gray-400 font-normal">(select all that apply)</span></label>
                  <div class="flex flex-wrap gap-2 resp-chips-container">
                    <button type="button" class="resp-chip">Built APIs / Backend</button>
                    <button type="button" class="resp-chip">Developed UI / Frontend</button>
                    <button type="button" class="resp-chip">Database Design</button>
                    <button type="button" class="resp-chip">Code Reviews</button>
                    <button type="button" class="resp-chip">System Design</button>
                    <button type="button" class="resp-chip">Bug Fixing</button>
                    <button type="button" class="resp-chip">Testing / QA</button>
                    <button type="button" class="resp-chip">CI/CD / DevOps</button>
                    <button type="button" class="resp-chip">Mentored Juniors</button>
                    <button type="button" class="resp-chip">Led a Team</button>
                    <button type="button" class="resp-chip">Client Communication</button>
                    <button type="button" class="resp-chip">Agile / Scrum</button>
                    <button type="button" class="resp-chip">Sales / BD</button>
                    <button type="button" class="resp-chip">Data Analysis</button>
                    <button type="button" class="resp-chip">Report Writing</button>
                    <button type="button" class="resp-chip">Training / L&D</button>
                    <button type="button" class="resp-chip">Recruitment</button>
                    <button type="button" class="resp-chip">Finance / Accounts</button>
                    <button type="button" class="resp-chip">Operations</button>
                    <button type="button" class="resp-chip">Marketing / SEO</button>
                    <button type="button" class="resp-chip">Content Writing</button>
                    <button type="button" class="resp-chip">Design / Creative</button>
                    <button type="button" class="resp-chip">Research</button>
                    <button type="button" class="resp-chip">Supply Chain</button>
                  </div>
                </div>
                <div>
                  <label class="block text-xs font-semibold text-gray-600 mb-1.5">Achievements / Impact <span class="text-gray-400 font-normal">(AI will add metrics)</span></label>
                  <textarea rows="2" placeholder="e.g. Increased sales by 30%, managed team of 5, reduced costs by ₹2L/month..."
                    class="w-full border border-gray-200 rounded-xl px-3 py-2 text-sm placeholder-gray-300 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent resize-none transition-all bg-white"></textarea>
                </div>
              </div>
            </div>
            <button id="add-exp" type="button" class="w-full border-2 border-dashed border-gray-200 rounded-xl py-3 text-sm text-gray-400 hover:border-brand-400 hover:text-brand-600 transition-all flex items-center justify-center gap-2 mt-3">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
              Add Another Job
            </button>
          </div>

          <!-- ── FRESHER: projects + internships + activities ── -->
          <div id="exp-fresher-section" class="hidden space-y-5">

            <!-- Info banner -->
            <div class="bg-blue-50 border border-blue-100 rounded-xl p-4 flex gap-3">
              <span class="text-2xl">🎓</span>
              <div>
                <div class="text-sm font-semibold text-blue-800 mb-0.5">No work experience? No problem.</div>
                <p class="text-xs text-blue-600 leading-relaxed">AI will build a strong resume using your projects, internships, and activities. Freshers get hired every day — the key is presenting what you have well.</p>
              </div>
            </div>

            <!-- Internship (optional) -->
            <div>
              <div class="flex items-center gap-2 mb-3">
                <div class="w-5 h-5 bg-purple-100 rounded flex items-center justify-center text-purple-600 text-xs">📋</div>
                <span class="text-sm font-semibold text-gray-800">Internship / Training</span>
                <span class="text-xs text-gray-400 ml-1">— optional</span>
              </div>
              <div class="bg-gray-50 rounded-xl p-4 space-y-3 border border-gray-100">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                  <div>
                    <label class="block text-xs font-semibold text-gray-600 mb-1.5">Role / Position</label>
                    <input type="text" id="fresher-intern-role" placeholder="e.g. Web Dev Intern, Marketing Intern..." class="form-input bg-white" />
                  </div>
                  <div>
                    <label class="block text-xs font-semibold text-gray-600 mb-1.5">Company / Organisation</label>
                    <input type="text" id="fresher-intern-company" placeholder="e.g. TCS, Local NGO, College Lab..." class="form-input bg-white" />
                  </div>
                  <div>
                    <label class="block text-xs font-semibold text-gray-600 mb-1.5">Duration</label>
                    <select id="fresher-intern-duration" class="form-select bg-white">
                      <option value="">Select duration</option>
                      <option>1 month</option>
                      <option>2 months</option>
                      <option>3 months</option>
                      <option>6 months</option>
                      <option>1 year</option>
                      <option>Other</option>
                    </select>
                  </div>
                  <div>
                    <label class="block text-xs font-semibold text-gray-600 mb-1.5">Type</label>
                    <select id="fresher-intern-type" class="form-select bg-white">
                      <option value="">Select type</option>
                      <option>Paid Internship</option>
                      <option>Unpaid Internship</option>
                      <option>Industrial Training</option>
                      <option>Vocational Training</option>
                      <option>Summer Project</option>
                      <option>Research Internship</option>
                      <option>Virtual / Online Internship</option>
                    </select>
                  </div>
                </div>
                <div>
                  <label class="block text-xs font-semibold text-gray-600 mb-1.5">What did you do? <span class="text-gray-400 font-normal">(AI will rewrite this professionally)</span></label>
                  <textarea id="fresher-intern-desc" rows="2" placeholder="e.g. Built a login page using HTML/CSS, helped with data entry, assisted in social media posts..."
                    class="w-full border border-gray-200 rounded-xl px-3 py-2 text-sm placeholder-gray-300 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent resize-none transition-all bg-white"></textarea>
                </div>
              </div>
            </div>

            <!-- Academic Projects -->
            <div>
              <div class="flex items-center gap-2 mb-3">
                <div class="w-5 h-5 bg-brand-100 rounded flex items-center justify-center text-brand-600 text-xs">💡</div>
                <span class="text-sm font-semibold text-gray-800">Academic / Personal Projects</span>
                <span class="text-xs text-accent-600 font-medium ml-1">— very important for freshers</span>
              </div>
              <div id="fresher-projects" class="space-y-3">
                <div class="fresher-project bg-gray-50 rounded-xl p-4 space-y-3 border border-gray-100">
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    <div>
                      <label class="block text-xs font-semibold text-gray-600 mb-1.5">Project Name</label>
                      <input type="text" placeholder="e.g. E-commerce Website, Hospital Management System..." class="form-input bg-white" />
                    </div>
                    <div>
                      <label class="block text-xs font-semibold text-gray-600 mb-1.5">Project Type</label>
                      <select class="form-select bg-white">
                        <option value="">Select type</option>
                        <option>Final Year Project</option>
                        <option>Mini Project</option>
                        <option>Personal / Side Project</option>
                        <option>Hackathon Project</option>
                        <option>Open Source Contribution</option>
                        <option>Research Project</option>
                        <option>Freelance Project</option>
                      </select>
                    </div>
                    <div class="sm:col-span-2">
                      <label class="block text-xs font-semibold text-gray-600 mb-1.5">Technologies / Tools Used</label>
                      <input type="text" placeholder="e.g. React, Node.js, MySQL — or Excel, Tally, Photoshop..." class="form-input bg-white" />
                    </div>
                  </div>
                  <div>
