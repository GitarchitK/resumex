    // Experience
    if (d.experience && d.experience.length > 0) {
      html += `<section class="mb-4"><h2 class="rr-section-title">Experience</h2><div class="space-y-4">`;
      d.experience.forEach((exp: any) => {
        const start = fmtMonth(exp.startDate);
        const end = exp.isCurrent ? 'Present' : fmtMonth(exp.endDate);
        const dateRange = start ? `${start} – ${end}` : '';
        html += `<div>
          <div class="flex items-start justify-between gap-2">
            <div>
              <div class="text-sm font-bold text-gray-900">${exp.title}${exp.type ? ' <span class="text-xs font-normal text-gray-400">· ' + exp.type + '</span>' : ''}</div>
              <div class="text-xs font-semibold text-gray-600">${exp.company}${exp.location ? ' · ' + exp.location : ''}</div>
            </div>
            ${dateRange ? `<div class="text-xs text-gray-500 whitespace-nowrap mt-0.5">${dateRange}</div>` : ''}
          </div>`;

        if (exp.responsibilities.length > 0 || exp.achievements) {
          html += `<ul class="mt-1.5 space-y-1 text-xs text-gray-700 leading-relaxed">`;
          exp.responsibilities.forEach((r: string) => {
            html += `<li class="flex gap-2"><span class="flex-shrink-0">•</span><span>${r}</span></li>`;
          });
          if (exp.achievements) {
            exp.achievements.split('\n').filter((l: string) => l.trim()).forEach((line: string) => {
              html += `<li class="flex gap-2"><span class="flex-shrink-0">•</span><span>${line.trim().replace(/^[-•]\s*/, '')}</span></li>`;
            });
          }
          html += `</ul>`;
        }
        html += `</div>`;
      });
