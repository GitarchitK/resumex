  // ── ATS Scoring Engine ──
  function scoreResume(data: any): {
    score: number;
    breakdown: { label: string; score: number; max: number; detail: string }[];
    issues: { type: 'error'|'warn'|'ok'; text: string }[];
    suggestions: string[];
  } {
    const text = data.mode === 'fix'
      ? (data.resumeText || '').toLowerCase()
      : buildResumeText(data).toLowerCase();

    const issues: { type: 'error'|'warn'|'ok'; text: string }[] = [];
    const suggestions: string[] = [];
    let breakdown: { label: string; score: number; max: number; detail: string }[] = [];

    // ── 1. Contact Info (10 pts) ──
    let contactScore = 0;
    const hasEmail = /[a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,}/.test(text);
    const hasPhone = /(\+91|0)?[\s-]?[6-9]\d{9}|(\d{3}[\s.-]\d{3}[\s.-]\d{4})/.test(text);
    const hasLinkedIn = /linkedin\.com/.test(text);
    const hasGithub = /github\.com|portfolio|behance|dribbble/.test(text);
    if (hasEmail) contactScore += 4; else issues.push({ type: 'error', text: 'Missing email address' });
    if (hasPhone) contactScore += 3; else issues.push({ type: 'warn', text: 'Missing phone number' });
    if (hasLinkedIn) contactScore += 2; else suggestions.push('Add your LinkedIn profile URL (+2 pts)');
    if (hasGithub) contactScore += 1; else suggestions.push('Add GitHub / portfolio link (+1 pt)');
    breakdown.push({ label: 'Contact Info', score: contactScore, max: 10, detail: `Email ${hasEmail?'✓':'✗'} · Phone ${hasPhone?'✓':'✗'} · LinkedIn ${hasLinkedIn?'✓':'✗'}` });

    // ── 2. Summary / Objective (10 pts) ──
    let summaryScore = 0;
    const hasSummary = /summary|objective|profile|about/.test(text);
    const summaryLen = data.mode === 'new' ? (data.summary || '').length : (text.match(/summary[\s\S]{20,400}/i)?.[0]?.length || 0);
    if (hasSummary) summaryScore += 5;
    if (summaryLen > 100) summaryScore += 3;
    if (/year|experience|expertise|speciali/.test(text)) summaryScore += 2;
    if (!hasSummary) issues.push({ type: 'error', text: 'No professional summary found' });
    else if (summaryLen < 80) issues.push({ type: 'warn', text: 'Summary is too short (aim for 2–3 sentences)' });
    breakdown.push({ label: 'Summary', score: summaryScore, max: 10, detail: hasSummary ? (summaryLen > 100 ? 'Strong summary' : 'Summary present but brief') : 'Missing' });

    // ── 3. Work Experience (25 pts) ──
    let expScore = 0;
    const hasExp = /experience|internship|work|employment|position|role/.test(text);
    const bulletCount = (text.match(/•|·|–|-\s+[a-z]/g) || []).length;
    const hasMetrics = /\d+%|\d+x|\d+\+|₹\d|rs\.\s*\d|\$\d|\d+\s*(lakh|crore|million|k\b|users|clients|customers|projects|bugs|features|days|weeks|months)/.test(text);
    const actionVerbs = ['built','developed','designed','led','managed','created','implemented','delivered','optimized','reduced','increased','improved','launched','architected','engineered','automated','deployed','migrated','scaled','mentored','collaborated','achieved','generated','saved','grew','drove','spearheaded','streamlined','established','coordinated','executed','analyzed','resolved','maintained','integrated','configured','monitored','trained','supervised','negotiated','presented','researched','published','authored','facilitated','administered','processed','handled','supported','assisted','contributed'];
    const verbCount = actionVerbs.filter(v => text.includes(v)).length;
    if (hasExp) expScore += 8;
    if (bulletCount >= 3) expScore += 5; else if (bulletCount > 0) expScore += 2;
    if (hasMetrics) expScore += 7; else issues.push({ type: 'error', text: 'No quantifiable metrics found (%, numbers, ₹)' });
    if (verbCount >= 5) expScore += 5; else if (verbCount >= 2) expScore += 3; else issues.push({ type: 'warn', text: 'Use stronger action verbs (Built, Led, Delivered...)' });
    if (!hasExp) issues.push({ type: 'error', text: 'No work experience section found' });
    breakdown.push({ label: 'Experience', score: expScore, max: 25, detail: `${bulletCount} bullets · ${verbCount} action verbs · Metrics: ${hasMetrics?'Yes':'No'}` });

    // ── 4. Skills (20 pts) ──
    let skillsScore = 0;
    const hasSkills = /skills|technologies|tools|stack|proficiencies/.test(text);
    const skillWords = data.mode === 'new' ? (data.skills || []) : [];
    const skillCount = data.mode === 'new' ? skillWords.length : (text.match(/\b(java|python|javascript|typescript|react|node|sql|aws|docker|git|excel|tally|sap|photoshop|figma|html|css|c\+\+|kotlin|swift|go|rust|php|ruby|spring|django|flask|mongodb|postgresql|mysql|redis|kubernetes|terraform|powerbi|tableau|salesforce|hubspot)\b/gi) || []).length;
    const hasCategories = /languages|frontend|backend|databases|tools|frameworks|cloud|devops/.test(text);
    if (hasSkills) skillsScore += 5;
    if (skillCount >= 8) skillsScore += 8; else if (skillCount >= 4) skillsScore += 5; else if (skillCount >= 1) skillsScore += 2;
    if (hasCategories) skillsScore += 4; else suggestions.push('Organize skills by category (Languages, Tools, etc.) (+4 pts)');
    if (skillCount >= 6) skillsScore += 3;
    if (!hasSkills) issues.push({ type: 'error', text: 'No skills section found' });
    else if (skillCount < 4) issues.push({ type: 'warn', text: 'Add more relevant skills (aim for 8+)' });
    breakdown.push({ label: 'Skills', score: skillsScore, max: 20, detail: `${skillCount} skills detected · Categorized: ${hasCategories?'Yes':'No'}` });

    // ── 5. Education (15 pts) ──
    let eduScore = 0;
    const hasEdu = /education|degree|university|college|b\.tech|m\.tech|bca|mca|mba|b\.sc|b\.com|diploma|12th|10th/.test(text);
    const hasCgpa = /cgpa|gpa|percentage|%|marks/.test(text);
    const hasYear = /20(1[5-9]|2[0-9])/.test(text);
    if (hasEdu) eduScore += 8;
    if (hasCgpa) eduScore += 4; else suggestions.push('Add your CGPA or percentage (+4 pts)');
    if (hasYear) eduScore += 3;
    if (!hasEdu) issues.push({ type: 'error', text: 'No education section found' });
    breakdown.push({ label: 'Education', score: eduScore, max: 15, detail: hasEdu ? `${hasCgpa?'CGPA included':'No CGPA'} · ${hasYear?'Year included':'No year'}` : 'Missing' });

    // ── 6. Formatting (10 pts) ──
    let fmtScore = 0;
    const wordCount = text.split(/\s+/).length;
    const hasProperLength = wordCount >= 200 && wordCount <= 800;
    const hasSections = (text.match(/\n[A-Z][A-Z\s]{3,}/g) || []).length >= 2;
    const noSpecialChars = !/(★|☆|✦|emoji|🔥|💼)/.test(text);
    if (hasProperLength) fmtScore += 4; else if (wordCount < 200) issues.push({ type: 'warn', text: `Resume too short (${wordCount} words, aim for 300–600)` });
    else issues.push({ type: 'warn', text: `Resume too long (${wordCount} words, keep under 700)` });
    if (hasSections) fmtScore += 3;
    if (noSpecialChars) fmtScore += 3;
    breakdown.push({ label: 'Formatting', score: fmtScore, max: 10, detail: `${wordCount} words · ${hasSections?'Clear sections':'Unclear structure'}` });

    // ── 7. JD Match (10 pts, only if JD provided) ──
    const jd = (data.jd || data.mode === 'fix' ? data.jd : data.jd || '').toLowerCase();
    let jdScore = 0;
    if (jd && jd.length > 50) {
      const jdWords = jd.match(/\b[a-z]{4,}\b/g) || [];
      const uniqueJdWords = [...new Set(jdWords)].filter(w => !['with','that','this','from','have','will','your','their','they','been','were','what','when','where','which','about','into','more','also','some','such','than','then','these','those','would','could','should','must','need','able','make','take','give','work','team','role','good','best','high','new','our','the','and','for','are','not','but','can','all','any','use','may','per','its','has','had','was','did','get','set','put','run','let','see','say','try','ask','end','add','way','day','time','year','part','case','back','each','just','like','only','even','both','well','also','very','most','over','same','last','long','made','many','much','next','once','open','own','real','show','side','size','small','still','such','sure','take','tell','than','them','then','they','this','thus','till','true','turn','type','upon','used','user','uses','view','want','ways','week','went','were','what','when','whom','wide','will','with','word','work','year','your'].includes(w));
      const matched = uniqueJdWords.filter(w => text.includes(w)).length;
      const matchPct = Math.min(100, Math.round((matched / Math.max(uniqueJdWords.length, 1)) * 100));
      jdScore = Math.round((matchPct / 100) * 10);
      if (matchPct < 40) issues.push({ type: 'warn', text: `Low JD keyword match (${matchPct}%) — add more role-specific terms` });
      breakdown.push({ label: 'JD Match', score: jdScore, max: 10, detail: `${matched}/${uniqueJdWords.length} keywords matched (${matchPct}%)` });
    } else {
      jdScore = 5; // neutral if no JD
      breakdown.push({ label: 'JD Match', score: 5, max: 10, detail: 'No JD provided — paste JD for accurate match' });
      suggestions.push('Paste the job description for targeted keyword matching (+up to 10 pts)');
    }

    const total = breakdown.reduce((s, b) => s + b.score, 0);
    const maxTotal = breakdown.reduce((s, b) => s + b.max, 0);
    const finalScore = Math.round((total / maxTotal) * 100);

    // Add positive issues
    if (hasMetrics) issues.push({ type: 'ok', text: 'Quantifiable metrics found ✓' });
    if (verbCount >= 4) issues.push({ type: 'ok', text: `${verbCount} strong action verbs used ✓` });
    if (hasLinkedIn) issues.push({ type: 'ok', text: 'LinkedIn profile included ✓' });

    return { score: finalScore, breakdown, issues, suggestions };
  }

  // Build plain text from new-mode form data for scoring
  function buildResumeText(data: any): string {
    const parts: string[] = [];
    if (data.name) parts.push(data.name);
    if (data.email) parts.push(data.email);
    if (data.phone) parts.push(data.phone);
    if (data.linkedin) parts.push(data.linkedin);
    if (data.github) parts.push(data.github);
    if (data.summary) parts.push('SUMMARY\n' + data.summary);
    if (data.experience?.length) {
      parts.push('EXPERIENCE');
      data.experience.forEach((e: any) => {
        parts.push(`${e.title} ${e.company}`);
        if (e.responsibilities?.length) parts.push(e.responsibilities.join('\n'));
        if (e.achievements) parts.push(e.achievements);
      });
    }
    if (data.education?.length) {
      parts.push('EDUCATION');
      data.education.forEach((e: any) => parts.push(`${e.degree} ${e.branch} ${e.college} ${e.cgpa}`));
    }
    if (data.skills?.length) parts.push('SKILLS\n' + data.skills.join(', '));
    if (data.certifications) parts.push('CERTIFICATIONS\n' + data.certifications);
    if (data.projects) parts.push('PROJECTS\n' + data.projects);
    return parts.join('\n');
  }

  // ── Render ATS score into the sidebar ──
  function renderATSScore(data: any) {
    const result = scoreResume(data);
    const { score, breakdown, issues, suggestions } = result;

    // Animate score number
    const numEl = document.getElementById('ats-score-num')!;
    const barEl = document.getElementById('ats-score-bar')!;
    const labelEl = document.getElementById('ats-score-label')!;
    const prevEl = document.getElementById('ats-score-prev')!;
    const deltaEl = document.getElementById('ats-score-delta')!;

    // Color based on score
    const color = score >= 75 ? 'text-accent-600' : score >= 55 ? 'text-brand-600' : 'text-orange-500';
    numEl.className = `text-6xl font-extrabold leading-none ${color}`;

    // Animate count up
    let current = 0;
    const step = Math.ceil(score / 40);
    const counter = setInterval(() => {
      current = Math.min(current + step, score);
      numEl.textContent = String(current);
      if (current >= score) clearInterval(counter);
    }, 30);

    // Bar
    setTimeout(() => { barEl.style.width = `${score}%`; }, 100);

    // Label
    const label = score >= 80 ? 'Excellent · Passes most ATS systems' :
                  score >= 65 ? 'Good · Passes most ATS systems' :
                  score >= 50 ? 'Fair · May fail some ATS filters' :
                  'Needs work · Likely to be filtered out';
    labelEl.textContent = `${score}/100 · ${label}`;

    // Before score estimate (rough — what it would have been without optimization)
    const beforeScore = Math.max(10, score - Math.floor(Math.random() * 15 + 20));
    prevEl.innerHTML = `<span class="line-through text-gray-400">was ~${beforeScore}</span>`;
    deltaEl.textContent = `+${score - beforeScore} points`;

    // Breakdown bars
    const breakdownEl = document.getElementById('ats-breakdown')!;
    breakdownEl.innerHTML = breakdown.map(b => {
      const pct = Math.round((b.score / b.max) * 100);
      const barColor = pct >= 70 ? 'from-accent-400 to-accent-500' : pct >= 40 ? 'from-brand-400 to-brand-500' : 'from-orange-400 to-red-400';
      return `<div>
        <div class="flex justify-between text-xs mb-1">
          <span class="text-gray-600">${b.label}</span>
          <span class="font-semibold text-gray-800">${b.score}/${b.max}</span>
        </div>
        <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden">
          <div class="h-full bg-gradient-to-r ${barColor} rounded-full transition-all duration-700" style="width:${pct}%"></div>
        </div>
        <div class="text-xs text-gray-400 mt-0.5">${b.detail}</div>
      </div>`;
    }).join('');

    // Issues
    const issuesEl = document.getElementById('ats-issues')!;
    const errors = issues.filter(i => i.type === 'error');
    const warns = issues.filter(i => i.type === 'warn');
    const oks = issues.filter(i => i.type === 'ok');
    issuesEl.innerHTML = [
      ...errors.map(i => `<li class="flex items-start gap-2 text-xs"><span class="w-4 h-4 rounded-full bg-red-500 flex items-center justify-center flex-shrink-0 text-white font-bold mt-0.5">✗</span><span class="text-gray-700">${i.text}</span></li>`),
      ...warns.map(i => `<li class="flex items-start gap-2 text-xs"><span class="w-4 h-4 rounded-full bg-orange-400 flex items-center justify-center flex-shrink-0 text-white font-bold mt-0.5">!</span><span class="text-gray-700">${i.text}</span></li>`),
      ...oks.map(i => `<li class="flex items-start gap-2 text-xs"><span class="w-4 h-4 rounded-full bg-accent-500 flex items-center justify-center flex-shrink-0 text-white font-bold mt-0.5">✓</span><span class="text-gray-600">${i.text}</span></li>`),
    ].join('') || '<li class="text-xs text-gray-400">No major issues found.</li>';

    // Suggestions
    const suggestionsEl = document.getElementById('ats-suggestions')!;
    suggestionsEl.innerHTML = suggestions.length
      ? suggestions.map(s => `<li class="flex items-start gap-2"><span class="text-yellow-500">💡</span>${s}</li>`).join('')
      : '<li class="text-gray-400">Resume looks complete. Great job!</li>';
  }

  // ── Render resume into output div ──
  function renderResume(data: any) {
    const output = document.getElementById('resume-output')!;
    output.innerHTML = buildResumeHTML(data);
    applyResumeProtection(output);
    renderATSScore(data);
  }

  function applyResumeProtection(container: HTMLElement) {
    // Watermark overlay
    const wm = document.createElement('div');
    wm.className = 'wm-layer';
    wm.setAttribute('aria-hidden', 'true');
    container.style.position = 'relative';
    container.appendChild(wm);

    // Blur overlay
    const blur = document.createElement('div');
    blur.id = 'blur-overlay-dynamic';
    blur.className = 'blur-overlay';
    blur.innerHTML = `
      <div class="blur-gradient"></div>
      <div class="blur-cta">
        <div class="blur-lock-icon">
          <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
        </div>
        <p class="text-white font-bold text-base mb-1">Your resume is ready</p>
        <p class="text-white/80 text-xs mb-4">Pay ₹9 to unlock & download the full PDF</p>
        <button onclick="document.getElementById('paywall-modal').classList.remove('hidden')"
          class="bg-white text-blue-700 font-bold text-sm px-6 py-2.5 rounded-xl hover:bg-blue-50 transition-all shadow-lg">
          Download PDF – ₹9
        </button>
        <p class="text-white/50 text-xs mt-2">UPI · GPay · PhonePe · Paytm</p>
      </div>`;
    container.appendChild(blur);

    // Block interactions
    container.addEventListener('contextmenu', e => e.preventDefault());
    container.style.userSelect = 'none';
    container.addEventListener('copy', e => { e.preventDefault(); });
  }

  // ── AI flow ──
  const screenInput = document.getElementById('screen-input')!;
  const screenLoading = document.getElementById('screen-loading')!;
  const screenResult = document.getElementById('screen-result')!;
  let collectedData: any = null;

  function startLoading() {
    collectedData = collectFormData();
    screenInput.classList.add('hidden');
    screenLoading.classList.remove('hidden');
    window.scrollTo({ top: 0, behavior: 'smooth' });
    const steps = ['step1','step2','step3','step4','step5'];
    const texts = ['Analyzing resume...','Identifying improvements...','Optimizing for ATS...','Rewriting bullet points...','Almost done!'];
    let i = 0;
    const interval = setInterval(() => {
      if (i < steps.length) {
        const el = document.getElementById(steps[i])!;
        el.classList.remove('opacity-30'); el.classList.add('opacity-100');
        el.querySelector('.step-icon')!.innerHTML = `<svg class="w-3 h-3 text-accent-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>`;
        document.getElementById('loading-text')!.textContent = texts[i];
        i++;
      } else {
        clearInterval(interval);
        setTimeout(() => {
          screenLoading.classList.add('hidden');
          screenResult.classList.remove('hidden');
          renderResume(collectedData!);
        }, 600);
      }
    }, 700);
  }

  document.getElementById('btn-fix')?.addEventListener('click', () => {
    const text = (document.getElementById('resume-input') as HTMLTextAreaElement).value;
    if (!text.trim() && !fileUpload?.files?.length) { alert('Please paste your resume or upload a file first.'); return; }
    startLoading();
  });

  document.getElementById('btn-build')?.addEventListener('click', () => {
    const name = (document.getElementById('n-name') as HTMLInputElement).value;
    if (!name.trim()) { alert('Please fill in your name first.'); goToStep(1); return; }
    startLoading();
  });

  document.getElementById('btn-restart')?.addEventListener('click', () => {
    screenResult.classList.add('hidden');
    screenInput.classList.remove('hidden');
    document.querySelectorAll('.loading-step').forEach(s => { s.classList.add('opacity-30'); s.classList.remove('opacity-100'); });
    document.querySelectorAll('.step-icon').forEach(ic => { ic.innerHTML = '<div class="w-2 h-2 rounded-full bg-gray-300"></div>'; });
    goToStep(1);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  document.getElementById('btn-download')?.addEventListener('click', () => {
    document.getElementById('paywall-modal')?.classList.remove('hidden');
  });

  // ── Payment + PDF download ──
  document.getElementById('btn-pay')?.addEventListener('click', async () => {
    const btn = document.getElementById('btn-pay') as HTMLButtonElement;
    const errEl = document.getElementById('pay-error')!;
    errEl.classList.add('hidden');
    btn.disabled = true;
    btn.textContent = 'Creating order...';

    try {
      // 1. Create Razorpay order server-side
      const orderRes = await fetch('/api/create-order', { method: 'POST' });
      const order = await orderRes.json();

      if (!order.success) throw new Error(order.error || 'Order creation failed');

      // 2. Open Razorpay checkout
      const options = {
        key: order.keyId,
        amount: order.amount,
        currency: order.currency,
        name: 'ResumeRocket AI',
        description: 'ATS-Optimized Resume PDF',
        order_id: order.orderId,
        prefill: {
          name: (document.getElementById('n-name') as HTMLInputElement)?.value || '',
          email: (document.getElementById('n-email') as HTMLInputElement)?.value || '',
          contact: (document.getElementById('n-phone') as HTMLInputElement)?.value || '',
        },
        theme: { color: '#2563eb' },
        modal: {
          ondismiss: () => {
            btn.disabled = false;
            btn.innerHTML = `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg> Pay ₹9 & Download PDF`;
          }
        },
        handler: async (response: any) => {
          // Payment successful — generate and download PDF
          btn.textContent = 'Generating PDF...';
          await downloadResumePDF();
          document.getElementById('paywall-modal')?.classList.add('hidden');
          btn.disabled = false;
          btn.innerHTML = `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg> Pay ₹9 & Download PDF`;
        },
      };

      const rzp = new (window as any).Razorpay(options);
      rzp.on('payment.failed', (resp: any) => {
        errEl.textContent = `Payment failed: ${resp.error.description}`;
        errEl.classList.remove('hidden');
        btn.disabled = false;
        btn.innerHTML = `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg> Pay ₹9 & Download PDF`;
      });
      rzp.open();

    } catch (err: any) {
      // If Razorpay keys not configured, fall back to direct print-to-PDF
      console.warn('Razorpay not configured, falling back to print:', err.message);
      await downloadResumePDF();
      document.getElementById('paywall-modal')?.classList.add('hidden');
      btn.disabled = false;
      btn.innerHTML = `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg> Pay ₹9 & Download PDF`;
    }
  });

  // ── Generate clean PDF via browser print ──
  async function downloadResumePDF() {
    const resumeContent = document.getElementById('resume-output')?.innerHTML || '';
    if (!resumeContent) return;

    // Open a clean print window with just the resume — no watermark, no blur
    const printWin = window.open('', '_blank', 'width=900,height=1200');
    if (!printWin) { alert('Please allow popups to download your resume.'); return; }

    printWin.document.write(`<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Resume — ResumeRocket AI</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', Arial, sans-serif;
      font-size: 11.5px;
      line-height: 1.5;
      color: #111827;
      background: white;
      padding: 2cm 2.2cm;
    }
    h1 { font-size: 22px; font-weight: 800; }
    .rr-section-title {
      font-size: 9px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #374151;
      border-bottom: 1px solid #d1d5db;
      padding-bottom: 2px;
      margin-bottom: 6px;
      margin-top: 14px;
    }
    /* Hide watermark and blur overlay */
    .wm-layer, .blur-overlay, #blur-overlay-dynamic { display: none !important; }
    a { color: #1d4ed8; text-decoration: none; }
    strong { font-weight: 600; }
    @page { margin: 0; size: A4; }
    @media print {
      body { padding: 1.5cm 1.8cm; }
    }
  </style>
</head>
<body>${resumeContent}</body>
</html>`);

    printWin.document.close();
    printWin.focus();

    // Wait for fonts to load then print
    setTimeout(() => {
      printWin.print();
      setTimeout(() => printWin.close(), 1000);
    }, 800);
  }
</script>
