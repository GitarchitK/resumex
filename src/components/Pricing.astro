---
---
<section id="pricing" class="py-20 px-4 sm:px-6 bg-white">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-12">
      <p class="text-sm font-semibold text-brand-600 uppercase tracking-widest mb-2">Pricing</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Stupidly simple pricing</h2>
      <p class="text-gray-500 mt-3">No subscriptions. No hidden fees. Just ₹9.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-2xl mx-auto">
      <!-- Free tier -->
      <div class="card border-2 border-gray-100 flex flex-col gap-4">
        <div>
          <div class="text-sm font-semibold text-gray-400 uppercase tracking-wide mb-1">Preview</div>
          <div class="text-4xl font-extrabold text-gray-900">Free</div>
          <div class="text-sm text-gray-400 mt-1">Always free</div>
        </div>
        <ul class="space-y-2.5 text-sm text-gray-600 flex-1">
          {[
            "Paste or upload resume",
            "AI analysis & suggestions",
            "ATS score check",
            "Blurred preview of result",
          ].map(item => (
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-accent-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              {item}
            </li>
          ))}
        </ul>
        <a href="/app" class="btn-secondary text-center text-sm">Try Free</a>
      </div>

      <!-- Paid tier -->
      <div class="card border-2 border-brand-500 flex flex-col gap-4 relative overflow-hidden">
        <div class="absolute top-4 right-4 bg-brand-600 text-white text-xs font-bold px-2 py-0.5 rounded-full">POPULAR</div>
        <div>
          <div class="text-sm font-semibold text-brand-600 uppercase tracking-wide mb-1">Download</div>
          <div class="flex items-end gap-2">
            <div class="text-4xl font-extrabold text-gray-900">₹9</div>
            <div class="text-sm text-gray-400 mb-1 line-through">₹299</div>
          </div>
          <div class="text-sm text-gray-400 mt-1">One-time payment</div>
        </div>
        <ul class="space-y-2.5 text-sm text-gray-600 flex-1">
          {[
            "Everything in Free",
            "Full optimized resume",
            "ATS-ready PDF download",
            "Clean professional template",
            "Job-specific keyword match",
            "Instant delivery",
          ].map(item => (
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-brand-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              {item}
            </li>
          ))}
        </ul>
        <a href="/app" class="btn-primary text-center text-sm">Get Started →</a>
        <p class="text-xs text-center text-gray-400">Pay via UPI · GPay · PhonePe · Paytm</p>
      </div>
    </div>
  </div>
</section>
