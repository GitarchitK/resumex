---
---
<section class="py-20 px-4 sm:px-6 bg-gray-50">
  <div class="max-w-6xl mx-auto">

    <div class="text-center mb-12">
      <p class="text-sm font-semibold text-brand-600 uppercase tracking-widest mb-2">Real Transformation</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Same person. Completely different resume.</h2>
      <p class="text-gray-500 mt-3 max-w-xl mx-auto text-sm">This is a real before/after from a B.Tech fresher. Every line was rewritten by AI — no fluff, just results.</p>
    </div>

    <!-- ATS Score bar -->
    <div class="flex items-center justify-center gap-6 mb-10">
      <div class="text-center">
        <div class="text-4xl font-extrabold text-red-500">43</div>
        <div class="text-xs text-gray-400 mt-1">Before · ATS Score</div>
      </div>
      <div class="flex-1 max-w-xs">
        <div class="relative h-3 bg-gray-200 rounded-full overflow-hidden">
          <div class="absolute left-0 top-0 h-full bg-red-400 rounded-full" style="width:43%"></div>
        </div>
        <div class="flex justify-between text-xs text-gray-400 mt-1">
          <span>0</span>
          <span class="text-accent-600 font-semibold">+46 points</span>
          <span>100</span>
        </div>
        <div class="relative h-3 bg-gray-200 rounded-full overflow-hidden mt-1">
          <div class="h-full bg-gradient-to-r from-brand-500 to-accent-500 rounded-full" style="width:89%"></div>
        </div>
      </div>
      <div class="text-center">
        <div class="text-4xl font-extrabold text-accent-600">89</div>
        <div class="text-xs text-gray-400 mt-1">After · ATS Score</div>
      </div>
    </div>

    <!-- Side by side resume — stacked on mobile with tab switcher -->
    <div class="rounded-2xl overflow-hidden shadow-xl border border-gray-200">

      <!-- Mobile tab switcher -->
      <div class="flex lg:hidden border-b border-gray-200">
        <button id="ba-tab-before" class="flex-1 py-3 text-sm font-bold text-red-500 bg-red-50 border-b-2 border-red-400 transition-all">✕ Before · ATS 43</button>
        <button id="ba-tab-after" class="flex-1 py-3 text-sm font-bold text-gray-400 bg-white border-b-2 border-transparent transition-all">✓ After · ATS 89</button>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 lg:divide-x lg:divide-gray-200">

      <!-- BEFORE column -->
      <div class="bg-white lg:border-r lg:border-gray-200" id="ba-before-panel">
        <!-- Header -->
        <div class="bg-red-50 border-b border-red-100 px-5 py-3 flex items-center justify-between sticky top-0 z-10">
          <div class="flex items-center gap-2">
            <span class="w-5 h-5 rounded-full bg-red-100 flex items-center justify-center">
              <svg class="w-3 h-3 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </span>
            <span class="text-sm font-bold text-red-600">Before</span>
          </div>
          <span class="text-xs font-bold text-red-500 bg-red-100 px-2.5 py-1 rounded-full">ATS Score: 43</span>
        </div>

        <div class="p-5 space-y-5 text-xs font-mono leading-relaxed text-gray-700">

          <!-- Name block -->
          <div class="space-y-0.5">
            <div class="text-sm font-bold text-gray-900">Rahul Kumar</div>
            <div class="text-gray-500">rahulkumar123@gmail.com | 9876543210</div>
            <div class="text-gray-500">B.Tech CSE, 2024</div>
          </div>

          <!-- Objective -->
          <div>
            <div class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1.5">Objective</div>
            <p class="text-gray-500 bg-red-50 border border-red-100 rounded-lg p-2.5 leading-relaxed">
              <span class="bad-line">To get a good job in a reputed company where I can use my skills and grow professionally and contribute to the organization's success.</span>
            </p>
            <div class="flex items-center gap-1 mt-1 text-red-400 text-xs">
              <svg class="w-3 h-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
              Generic filler — says nothing specific
            </div>
          </div>

          <!-- Experience -->
          <div>
            <div class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-2">Internship Experience</div>
            <div class="space-y-3">
              <div class="bg-red-50 border border-red-100 rounded-lg p-3">
                <div class="font-semibold text-gray-700">Web Developer Intern — XYZ Tech</div>
                <div class="text-gray-400 mb-2">June 2023 – Aug 2023</div>
                <ul class="space-y-1 text-gray-500">
                  <li class="bad-line flex gap-1.5"><span class="text-red-300 flex-shrink-0">•</span>Worked on the company website and made changes as required by the team.</li>
                  <li class="bad-line flex gap-1.5"><span class="text-red-300 flex-shrink-0">•</span>Helped in fixing bugs and doing testing of the application.</li>
                  <li class="bad-line flex gap-1.5"><span class="text-red-300 flex-shrink-0">•</span>Participated in daily standup meetings and team discussions.</li>
                  <li class="bad-line flex gap-1.5"><span class="text-red-300 flex-shrink-0">•</span>Learned new technologies during the internship period.</li>
                </ul>
                <div class="mt-2 flex flex-wrap gap-1">
                  <span class="issue-tag">No metrics</span>
                  <span class="issue-tag">Passive voice</span>
                  <span class="issue-tag">No impact</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Projects -->
          <div>
            <div class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-2">Projects</div>
            <div class="bg-red-50 border border-red-100 rounded-lg p-3 space-y-1">
              <div class="font-semibold text-gray-700">E-commerce Website</div>
              <p class="bad-line text-gray-500">Made a shopping website using HTML, CSS and JavaScript. It has login page, product listing and cart functionality.</p>
              <div class="mt-1 flex flex-wrap gap-1">
                <span class="issue-tag">No tech depth</span>
                <span class="issue-tag">No results</span>
              </div>
            </div>
          </div>

          <!-- Skills -->
          <div>
            <div class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-2">Skills</div>
            <div class="bg-red-50 border border-red-100 rounded-lg p-3">
              <p class="bad-line text-gray-500">C, C++, Java, Python, HTML, CSS, JavaScript, MySQL, MS Office, Photoshop, Communication, Teamwork, Leadership</p>
              <div class="mt-2 flex flex-wrap gap-1">
                <span class="issue-tag">Unorganized</span>
                <span class="issue-tag">Soft skills mixed in</span>
                <span class="issue-tag">No context</span>
              </div>
            </div>
          </div>

          <!-- Education -->
          <div>
            <div class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-2">Education</div>
            <div class="text-gray-700">B.Tech Computer Science — JNTU Hyderabad</div>
            <div class="text-gray-400">2020 – 2024 | CGPA: 7.8</div>
          </div>

        </div>
      </div>

      <!-- AFTER column -->
      <div class="bg-white hidden lg:block" id="ba-after-panel">
        <!-- Header -->
        <div class="bg-accent-500/5 border-b border-accent-500/20 px-5 py-3 flex items-center justify-between sticky top-0 z-10">
          <div class="flex items-center gap-2">
            <span class="w-5 h-5 rounded-full bg-accent-500/20 flex items-center justify-center">
              <svg class="w-3 h-3 text-accent-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </span>
            <span class="text-sm font-bold text-accent-600">After — AI Optimized</span>
          </div>
          <span class="text-xs font-bold text-accent-600 bg-accent-500/10 px-2.5 py-1 rounded-full">ATS Score: 89</span>
        </div>

        <div class="p-5 space-y-5 text-xs font-mono leading-relaxed text-gray-700">

          <!-- Name block -->
          <div class="space-y-0.5">
            <div class="text-sm font-bold text-gray-900">Rahul Kumar</div>
            <div class="text-gray-600">rahul.kumar@gmail.com · +91 98765 43210 · Hyderabad, India</div>
            <div class="good-line text-accent-700">linkedin.com/in/rahulkumar · github.com/rahulkumar</div>
            <span class="added-tag">+ LinkedIn & GitHub added</span>
          </div>

          <!-- Summary (replaced Objective) -->
          <div>
            <div class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1.5">
              <span class="good-line">Professional Summary</span>
              <span class="added-tag ml-2">Objective → Summary</span>
            </div>
            <p class="text-gray-700 bg-accent-500/5 border border-accent-500/20 rounded-lg p-2.5 leading-relaxed good-line">
              Full-stack developer with hands-on experience building production-grade web applications using React and Node.js. Delivered a 35% performance improvement during internship at XYZ Tech. Strong foundation in DSA with 300+ LeetCode problems solved. Seeking SDE-1 role to build scalable systems.
            </p>
            <span class="added-tag mt-1 inline-block">Role-specific · Metric-backed · Keyword-rich</span>
          </div>

          <!-- Experience -->
          <div>
            <div class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-2">Experience</div>
            <div class="space-y-3">
              <div class="bg-accent-500/5 border border-accent-500/20 rounded-lg p-3">
                <div class="font-semibold text-gray-800">Software Engineer Intern — XYZ Tech, Hyderabad</div>
                <div class="text-gray-500 mb-2">Jun 2023 – Aug 2023</div>
                <ul class="space-y-1.5 text-gray-700">
                  <li class="good-line flex gap-1.5"><span class="text-accent-500 flex-shrink-0">•</span>Redesigned 4 core UI components in React, reducing page load time by <strong>35%</strong> and improving Lighthouse score from 61 → 89.</li>
                  <li class="good-line flex gap-1.5"><span class="text-accent-500 flex-shrink-0">•</span>Identified and resolved <strong>12 critical bugs</strong> in the checkout flow, reducing cart abandonment by 18%.</li>
                  <li class="good-line flex gap-1.5"><span class="text-accent-500 flex-shrink-0">•</span>Wrote <strong>40+ unit tests</strong> using Jest, increasing code coverage from 52% to 78%.</li>
                  <li class="good-line flex gap-1.5"><span class="text-accent-500 flex-shrink-0">•</span>Collaborated in Agile sprints (2-week cycles), consistently delivering tasks <strong>on or ahead of schedule</strong>.</li>
                </ul>
                <div class="mt-2 flex flex-wrap gap-1">
                  <span class="fix-tag">Metrics added</span>
                  <span class="fix-tag">Action verbs</span>
                  <span class="fix-tag">Impact shown</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Projects -->
          <div>
            <div class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-2">Projects</div>
            <div class="bg-accent-500/5 border border-accent-500/20 rounded-lg p-3 space-y-1">
              <div class="flex items-center justify-between gap-2">
                <div class="font-semibold text-gray-800">ShopEase — Full-Stack E-Commerce Platform</div>
                <span class="added-tag">Name upgraded</span>
              </div>
              <p class="good-line text-gray-700">Built a full-stack e-commerce app using React, Node.js, Express, and MongoDB with JWT auth, Razorpay integration, and Redis caching. Handles <strong>500+ concurrent users</strong>; deployed on AWS EC2 with CI/CD via GitHub Actions.</p>
              <p class="text-gray-400 mt-1">React · Node.js · MongoDB · Redis · AWS · GitHub Actions</p>
              <div class="mt-1 flex flex-wrap gap-1">
                <span class="fix-tag">Tech stack detailed</span>
                <span class="fix-tag">Scale mentioned</span>
                <span class="fix-tag">Deployment added</span>
              </div>
            </div>
          </div>

          <!-- Skills -->
          <div>
            <div class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-2">Technical Skills</div>
            <div class="bg-accent-500/5 border border-accent-500/20 rounded-lg p-3 space-y-1.5">
              <div class="flex gap-2"><span class="font-semibold text-gray-700 w-24 flex-shrink-0">Languages</span><span class="good-line text-gray-700">Java, Python, JavaScript, C++, SQL</span></div>
              <div class="flex gap-2"><span class="font-semibold text-gray-700 w-24 flex-shrink-0">Frontend</span><span class="good-line text-gray-700">React, HTML5, CSS3, Tailwind CSS</span></div>
              <div class="flex gap-2"><span class="font-semibold text-gray-700 w-24 flex-shrink-0">Backend</span><span class="good-line text-gray-700">Node.js, Express, REST APIs, JWT</span></div>
              <div class="flex gap-2"><span class="font-semibold text-gray-700 w-24 flex-shrink-0">Databases</span><span class="good-line text-gray-700">MySQL, MongoDB, Redis</span></div>
              <div class="flex gap-2"><span class="font-semibold text-gray-700 w-24 flex-shrink-0">Tools</span><span class="good-line text-gray-700">Git, Docker, AWS EC2, GitHub Actions</span></div>
              <span class="fix-tag mt-1 inline-block">Organized by category · Soft skills removed</span>
            </div>
          </div>

          <!-- Education -->
          <div>
            <div class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-2">Education</div>
            <div class="flex justify-between items-start">
              <div>
                <div class="font-semibold text-gray-800">B.Tech, Computer Science & Engineering</div>
                <div class="text-gray-500">JNTU Hyderabad</div>
                <div class="good-line text-gray-600 mt-0.5">CGPA: 7.8/10 · Relevant: DSA, OS, DBMS, CN, System Design</div>
              </div>
              <div class="text-gray-400 whitespace-nowrap">2020 – 2024</div>
            </div>
            <span class="added-tag mt-1 inline-block">Relevant coursework added</span>
          </div>

        </div>
      </div><!-- /after panel -->
      </div><!-- /grid -->
    </div><!-- /rounded wrapper -->

    <!-- Bottom legend -->
    <div class="flex flex-wrap items-center justify-center gap-4 mt-6 text-xs">
      <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-red-100 border border-red-200 inline-block"></span> Weak / removed content</span>
      <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-accent-500/10 border border-accent-500/30 inline-block"></span> AI-improved content</span>
      <span class="flex items-center gap-1.5"><span class="issue-tag">tag</span> Problem identified</span>
      <span class="flex items-center gap-1.5"><span class="fix-tag">tag</span> Fix applied</span>
      <span class="flex items-center gap-1.5"><span class="added-tag">tag</span> New addition</span>
    </div>

  </div>
</section>

<style>
  .bad-line { text-decoration: line-through; color: #f87171; text-decoration-color: #fca5a5; }
  .good-line { color: #065f46; }
  .issue-tag { @apply text-xs bg-red-100 text-red-500 px-1.5 py-0.5 rounded font-medium; }
  .fix-tag { @apply text-xs bg-accent-500/10 text-accent-600 px-1.5 py-0.5 rounded font-medium; }
  .added-tag { @apply text-xs bg-brand-50 text-brand-600 px-1.5 py-0.5 rounded font-medium; }
</style>

<script>
  const baBefore = document.getElementById('ba-before-panel');
  const baAfter = document.getElementById('ba-after-panel');
  const baTabBefore = document.getElementById('ba-tab-before');
  const baTabAfter = document.getElementById('ba-tab-after');

  baTabBefore?.addEventListener('click', () => {
    baBefore?.classList.remove('hidden');
    baAfter?.classList.add('hidden');
    baTabBefore.className = 'flex-1 py-3 text-sm font-bold text-red-500 bg-red-50 border-b-2 border-red-400 transition-all';
    baTabAfter!.className = 'flex-1 py-3 text-sm font-bold text-gray-400 bg-white border-b-2 border-transparent transition-all';
  });

  baTabAfter?.addEventListener('click', () => {
    baAfter?.classList.remove('hidden');
    baBefore?.classList.add('hidden');
    baTabAfter.className = 'flex-1 py-3 text-sm font-bold text-accent-600 bg-accent-500/5 border-b-2 border-accent-500 transition-all';
    baTabBefore!.className = 'flex-1 py-3 text-sm font-bold text-gray-400 bg-white border-b-2 border-transparent transition-all';
  });
</script>
