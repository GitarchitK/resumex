                <div class="text-xs text-gray-400 mb-1">Jun–Aug 2023</div>
                <ul class="space-y-0.5">
                  <li class="hero-bad-text flex gap-1"><span class="text-red-300">•</span>Worked on the company website and made changes.</li>
                  <li class="hero-bad-text flex gap-1"><span class="text-red-300">•</span>Helped in fixing bugs and doing testing.</li>
                  <li class="hero-bad-text flex gap-1"><span class="text-red-300">•</span>Participated in daily standup meetings.</li>
                </ul>
              </div>

              <!-- Skills -->
              <div>
                <div class="hero-section-label">Skills</div>
                <p class="hero-bad-text">C, C++, Java, Python, HTML, CSS, MySQL, MS Office, Communication, Teamwork</p>
              </div>

              <!-- ATS issues -->
              <div class="flex flex-wrap gap-1 pt-1">
                <span class="hero-issue-tag">No metrics</span>
                <span class="hero-issue-tag">Weak verbs</span>
                <span class="hero-issue-tag">No keywords</span>
              </div>
            </div>
          </div>

          <!-- AFTER -->
          <div class="bg-white">
            <div class="bg-accent-500/5 border-b border-accent-500/20 px-4 py-2 flex items-center justify-between">
              <span class="text-xs font-bold text-accent-600 flex items-center gap-1.5">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
