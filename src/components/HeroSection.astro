---
<section class="pt-32 pb-20 px-4 sm:px-6 bg-gradient-to-b from-gray-50 to-white relative overflow-hidden">
  <!-- Background blobs -->
  <div class="absolute top-20 left-1/4 w-72 h-72 bg-brand-100 rounded-full blur-3xl opacity-40 pointer-events-none"></div>
  <div class="absolute top-32 right-1/4 w-64 h-64 bg-accent-400/20 rounded-full blur-3xl opacity-40 pointer-events-none"></div>

  <div class="max-w-4xl mx-auto text-center relative z-10">
    <!-- Trust badge -->
    <div class="inline-flex items-center gap-2 bg-accent-500/10 text-accent-600 text-sm font-medium px-4 py-1.5 rounded-full mb-6 border border-accent-500/20">
      <span class="w-2 h-2 bg-accent-500 rounded-full animate-pulse"></span>
      No signup required · 100% free to try
    </div>

    <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold text-gray-900 leading-tight mb-6">
      Fix Your Resume in
      <span class="bg-gradient-to-r from-brand-600 to-accent-500 bg-clip-text text-transparent"> 60 Seconds</span>
    </h1>

    <p class="text-lg sm:text-xl text-gray-500 max-w-2xl mx-auto mb-8 leading-relaxed">
      Get an ATS-optimized resume instantly. Beat the bots, land more interviews.
      <span class="text-gray-900 font-semibold">Pay only ₹9 to download.</span>
    </p>

    <div class="flex flex-col sm:flex-row gap-3 justify-center items-center mb-10">
      <a href="/app" class="btn-primary text-base w-full sm:w-auto text-center">
        Fix My Resume Free →
      </a>
      <a href="#how-it-works" class="btn-secondary text-base w-full sm:w-auto text-center">
        See how it works
      </a>
    </div>

    <!-- Social proof strip -->
    <div class="flex flex-wrap justify-center gap-6 text-sm text-gray-500">
      <span class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-accent-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
        12,000+ resumes improved
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-accent-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
        ATS score avg. +38 points
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-accent-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
        Trusted by IIT, NIT & DU students
      </span>
    </div>

    <!-- Hero mockup — real resume diff, mobile: stacked tabs, desktop: side by side -->
    <div class="mt-12 relative max-w-4xl mx-auto">
      <div class="bg-white rounded-2xl shadow-2xl border border-gray-200 overflow-hidden">

        <!-- Browser chrome -->
        <div class="bg-gray-100 border-b border-gray-200 px-4 py-2.5 flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-red-400"></span>
          <span class="w-3 h-3 rounded-full bg-yellow-400"></span>
          <span class="w-3 h-3 rounded-full bg-green-400"></span>
          <div class="ml-3 flex-1 bg-white rounded-md px-3 py-1 text-xs text-gray-400 font-mono text-left border border-gray-200 truncate">
            resumerocket.ai/app
          </div>
        </div>

        <!-- Mobile tab switcher (hidden on md+) -->
        <div class="flex md:hidden border-b border-gray-200">
          <button id="hero-tab-before" class="flex-1 py-2.5 text-xs font-bold text-red-500 bg-red-50 border-b-2 border-red-400 transition-all">✕ Before · ATS 43</button>
          <button id="hero-tab-after" class="flex-1 py-2.5 text-xs font-bold text-gray-400 bg-white border-b-2 border-transparent transition-all">✓ After · ATS 89</button>
        </div>

        <!-- Split diff view -->
        <div class="md:grid md:grid-cols-2 md:divide-x md:divide-gray-200 text-left">

          <!-- BEFORE -->
          <div class="bg-white" id="hero-before-panel">
            <div class="hidden md:flex bg-red-50 border-b border-red-100 px-4 py-2 items-center justify-between">
              <span class="text-xs font-bold text-red-500 flex items-center gap-1.5">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>Before
              </span>
              <span class="text-xs font-bold text-red-400 bg-red-100 px-2 py-0.5 rounded-full">ATS 43</span>
            </div>
            <div class="p-4 space-y-3 font-mono">
              <div>
                <div class="text-xs font-bold text-gray-800">Rahul Kumar</div>
                <div class="text-xs text-gray-400">rahulkumar123@gmail.com | 9876543210</div>
              </div>
              <div>
                <div class="hero-section-label">Objective</div>
                <p class="hero-bad-text">To get a good job in a reputed company where I can use my skills and grow professionally.</p>
              </div>
              <div>
                <div class="hero-section-label">Experience</div>
                <div class="text-xs font-semibold text-gray-600">Web Developer Intern — XYZ Tech</div>
                <div class="text-xs text-gray-400 mb-1">Jun–Aug 2023</div>
                <ul class="space-y-0.5">
                  <li class="hero-bad-text flex gap-1"><span class="text-red-300">•</span>Worked on the company website and made changes.</li>
                  <li class="hero-bad-text flex gap-1"><span class="text-red-300">•</span>Helped in fixing bugs and doing testing.</li>
                </ul>
              </div>
              <div>
                <div class="hero-section-label">Skills</div>
                <p class="hero-bad-text">C, C++, Java, Python, HTML, CSS, MySQL, MS Office, Communication, Teamwork</p>
              </div>
              <div class="flex flex-wrap gap-1 pt-1">
                <span class="hero-issue-tag">No metrics</span>
                <span class="hero-issue-tag">Weak verbs</span>
                <span class="hero-issue-tag">No keywords</span>
              </div>
            </div>
          </div>

          <!-- AFTER -->
          <div class="bg-white hidden md:block" id="hero-after-panel">
            <div class="hidden md:flex bg-accent-500/5 border-b border-accent-500/20 px-4 py-2 items-center justify-between">
              <span class="text-xs font-bold text-accent-600 flex items-center gap-1.5">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>After — AI Optimized
              </span>
              <span class="text-xs font-bold text-accent-600 bg-accent-500/10 px-2 py-0.5 rounded-full">ATS 89</span>
            </div>
            <div class="p-4 space-y-3 font-mono">
              <div>
                <div class="text-xs font-bold text-gray-800">Rahul Kumar</div>
                <div class="text-xs text-gray-500">rahul.kumar@gmail.com · +91 98765 43210</div>
                <div class="hero-good-text text-xs">linkedin.com/in/rahulkumar · github.com/rahulkumar</div>
              </div>
              <div>
                <div class="hero-section-label">Professional Summary <span class="hero-fix-tag ml-1">rewritten</span></div>
                <p class="hero-good-text">Full-stack dev with React & Node.js. Delivered <strong>35% perf boost</strong> at XYZ Tech. 300+ LeetCode. Seeking SDE-1 role.</p>
              </div>
              <div>
                <div class="hero-section-label">Experience</div>
                <div class="text-xs font-semibold text-gray-700">Software Engineer Intern — XYZ Tech</div>
                <div class="text-xs text-gray-400 mb-1">Jun–Aug 2023</div>
                <ul class="space-y-0.5">
                  <li class="hero-good-text flex gap-1"><span class="text-accent-500">•</span>Redesigned 4 UI components, cutting load time by <strong>35%</strong>.</li>
                  <li class="hero-good-text flex gap-1"><span class="text-accent-500">•</span>Fixed <strong>12 critical bugs</strong>, reducing cart abandonment 18%.</li>
                </ul>
              </div>
              <div>
                <div class="hero-section-label">Technical Skills <span class="hero-fix-tag ml-1">organized</span></div>
                <div class="space-y-0.5 text-xs text-gray-700">
                  <div><span class="font-semibold text-gray-500">Languages:</span> Java, Python, JS, C++</div>
                  <div><span class="font-semibold text-gray-500">Stack:</span> React, Node.js, MongoDB, Redis</div>
                </div>
              </div>
              <div class="flex flex-wrap gap-1 pt-1">
                <span class="hero-fix-tag">Metrics added</span>
                <span class="hero-fix-tag">Keywords matched</span>
                <span class="hero-fix-tag">ATS-ready</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Bottom bar -->
        <div class="bg-gray-50 border-t border-gray-100 px-4 py-2.5 flex items-center justify-between">
          <div class="flex items-center gap-2 sm:gap-3 text-xs text-gray-500">
            <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-red-400"></span> ATS 43</span>
            <svg class="w-3 h-3 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-accent-500"></span> ATS 89</span>
          </div>
          <a href="/app" class="text-xs font-semibold text-brand-600 hover:text-brand-700 transition-colors">Fix mine now →</a>
        </div>
      </div>
      <div class="absolute -inset-4 bg-gradient-to-r from-brand-500/10 to-accent-500/10 rounded-3xl blur-2xl -z-10"></div>
    </div>

          <!-- BEFORE -->
          <div class="bg-white">
            <div class="bg-red-50 border-b border-red-100 px-4 py-2 flex items-center justify-between">
              <span class="text-xs font-bold text-red-500 flex items-center gap-1.5">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                Before
              </span>
              <span class="text-xs font-bold text-red-400 bg-red-100 px-2 py-0.5 rounded-full">ATS 43</span>
            </div>
            <div class="p-4 space-y-3 font-mono text-left">

              <!-- Name -->
              <div>
