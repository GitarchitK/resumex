              </div>

              <!-- Objective -->
              <div>
                <div class="hero-section-label">Objective</div>
                <p class="hero-bad-text">To get a good job in a reputed company where I can use my skills and grow professionally.</p>
              </div>

              <!-- Experience -->
              <div>
