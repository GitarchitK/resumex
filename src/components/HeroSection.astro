</section>

<style>
  .hero-section-label { @apply text-xs font-bold text-gray-400 uppercase tracking-widest mb-1; }
  .hero-bad-text { @apply text-xs text-red-400 line-through leading-relaxed; text-decoration-color: #fca5a5; }
  .hero-good-text { @apply text-xs text-emerald-700 leading-relaxed; }
  .hero-issue-tag { @apply text-xs bg-red-100 text-red-500 px-1.5 py-0.5 rounded font-medium; }
  .hero-fix-tag { @apply text-xs bg-emerald-50 text-emerald-600 px-1.5 py-0.5 rounded font-medium; }
</style>

<script>
  const tabBefore = document.getElementById('hero-tab-before');
  const tabAfter = document.getElementById('hero-tab-after');
  const panelBefore = document.getElementById('hero-before-panel');
  const panelAfter = document.getElementById('hero-after-panel');

  tabBefore?.addEventListener('click', () => {
    panelBefore?.classList.remove('hidden');
    panelAfter?.classList.add('hidden');
    tabBefore.className = 'flex-1 py-2.5 text-xs font-bold text-red-500 bg-red-50 border-b-2 border-red-400 transition-all';
    tabAfter!.className = 'flex-1 py-2.5 text-xs font-bold text-gray-400 bg-white border-b-2 border-transparent transition-all';
  });

  tabAfter?.addEventListener('click', () => {
    panelAfter?.classList.remove('hidden');
    panelBefore?.classList.add('hidden');
    tabAfter.className = 'flex-1 py-2.5 text-xs font-bold text-accent-600 bg-accent-500/5 border-b-2 border-accent-500 transition-all';
    tabBefore!.className = 'flex-1 py-2.5 text-xs font-bold text-gray-400 bg-white border-b-2 border-transparent transition-all';
  });
</script>
