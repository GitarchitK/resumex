---
const faqs = [
  {
    q: "Is this resume ATS-friendly?",
    a: "Yes. Our AI specifically optimizes for Applicant Tracking Systems used by companies like TCS, Infosys, Wipro, Accenture, and most startups. It adds the right keywords, fixes formatting, and ensures clean parsing.",
  },
  {
    q: "Is it a one-time payment?",
    a: "Absolutely. You pay ₹9 once to download your optimized resume. No subscription, no monthly fees, no surprises.",
  },
  {
    q: "Do I need to create an account?",
    a: "No signup required. Just paste your resume, let AI improve it, and pay ₹9 to download. That's it.",
  },
  {
    q: "Is my resume data safe?",
    a: "Yes. We process your resume in memory and never store it on our servers. Your data is deleted immediately after you download. We take privacy seriously.",
  },
  {
    q: "What file formats are supported?",
    a: "You can paste resume text directly, or upload PDF and DOCX files. We support all common resume formats.",
  },
  {
    q: "Can I use it for multiple job applications?",
    a: "Yes. Each time you paste a different job description, the AI tailors your resume specifically for that role. Each download is ₹9.",
  },
];
---
<section id="faq" class="py-20 px-4 sm:px-6 bg-gray-50">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-12">
      <p class="text-sm font-semibold text-brand-600 uppercase tracking-widest mb-2">FAQ</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Common questions</h2>
    </div>

    <div class="space-y-3" id="faq-list">
      {faqs.map((faq, i) => (
        <div class="card cursor-pointer faq-item" data-index={i}>
          <div class="flex items-center justify-between gap-4">
            <h3 class="font-semibold text-gray-900 text-sm sm:text-base">{faq.q}</h3>
            <svg class="w-5 h-5 text-gray-400 flex-shrink-0 faq-icon transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </div>
          <div class="faq-answer hidden mt-3 text-sm text-gray-500 leading-relaxed">{faq.a}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.faq-item').forEach(item => {
    item.addEventListener('click', () => {
      const answer = item.querySelector('.faq-answer');
      const icon = item.querySelector('.faq-icon');
      const isOpen = !answer.classList.contains('hidden');
      // close all
      document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
      document.querySelectorAll('.faq-icon').forEach(ic => ic.style.transform = '');
      if (!isOpen) {
        answer.classList.remove('hidden');
        icon.style.transform = 'rotate(180deg)';
      }
    });
  });
</script>
