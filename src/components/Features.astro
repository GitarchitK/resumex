---
const features = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    title: "ATS Optimized",
    desc: "Passes Applicant Tracking Systems at top companies like TCS, Infosys, Wipro, and startups.",
    color: "text-accent-600 bg-accent-500/10",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
    title: "Job-Specific Tailoring",
    desc: "Paste any job description and AI matches your resume keywords to that exact role.",
    color: "text-brand-600 bg-brand-50",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
    title: "Instant Results",
    desc: "No waiting. Your improved resume is ready in under 30 seconds.",
    color: "text-yellow-600 bg-yellow-50",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/></svg>`,
    title: "Clean Templates",
    desc: "Professional, recruiter-approved templates that look great on screen and print.",
    color: "text-purple-600 bg-purple-50",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>`,
    title: "Private & Secure",
    desc: "Your resume data is never stored or shared. Processed and deleted immediately.",
    color: "text-gray-600 bg-gray-100",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>`,
    title: "UPI Payment",
    desc: "Pay ₹9 via any UPI app — GPay, PhonePe, Paytm. No card needed.",
    color: "text-orange-600 bg-orange-50",
  },
];
---
<section class="py-20 px-4 sm:px-6 bg-gray-50">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <p class="text-sm font-semibold text-brand-600 uppercase tracking-widest mb-2">Features</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Everything you need to get hired</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {features.map((f) => (
        <div class="card hover:shadow-md transition-all duration-200 hover:-translate-y-0.5 flex gap-4">
          <div class={`w-10 h-10 rounded-xl ${f.color} flex items-center justify-center flex-shrink-0`} set:html={f.icon} />
          <div>
            <h3 class="font-semibold text-gray-900 mb-1">{f.title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{f.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
